-- ── Unified send_notification() with rate limiting + Pro check ────────────────
CREATE OR REPLACE FUNCTION send_notification(
    p_user_id    UUID,
    p_type       TEXT,
    p_title      TEXT,
    p_message    TEXT,
    p_data       JSONB        DEFAULT '{}'::JSONB,
    p_pro_only   BOOLEAN      DEFAULT FALSE,
    p_window_key TEXT         DEFAULT NULL,
    p_rate_limit INT          DEFAULT 1   -- max per window key
) RETURNS BOOLEAN LANGUAGE plpgsql SECURITY DEFINER AS $$
DECLARE
    v_tier TEXT;
    v_window TEXT;
BEGIN
    -- Pro-only gate
    IF p_pro_only THEN
        SELECT st.name INTO v_tier
        FROM user_subscriptions us
        JOIN subscription_tiers  st ON st.id = us.tier_id
        WHERE us.user_id = p_user_id AND us.status = 'active'
        LIMIT 1;
        IF v_tier IS NULL OR v_tier = 'free' THEN
            RETURN FALSE;
        END IF;
    END IF;

    -- Rate-limit gate
    IF p_window_key IS NOT NULL THEN
        INSERT INTO notification_rate_limits(user_id, notif_type, window_key, count)
        VALUES (p_user_id, p_type, p_window_key, 1)
        ON CONFLICT (user_id, notif_type, window_key)
        DO UPDATE SET count = notification_rate_limits.count + 1;

        IF (SELECT count FROM notification_rate_limits
            WHERE user_id = p_user_id AND notif_type = p_type AND window_key = p_window_key
           ) > p_rate_limit THEN
            RETURN FALSE;
        END IF;
    END IF;

    -- Insert the notification
    INSERT INTO user_notifications(user_id, type, title, message, data)
    VALUES (p_user_id, p_type, p_title, p_message, p_data);

    -- Queue for push delivery (Edge Function will process)
    INSERT INTO notification_queue(user_id, notification_type, title, body, data, channel)
    VALUES (p_user_id, p_type, p_title, p_message, p_data, 'push')
    ON CONFLICT DO NOTHING;

    RETURN TRUE;
END $$;

