-- Drop ALL price-related triggers on the properties table first.
-- This kills any stale trigger (from any old schema version) that might
-- reference property_price_history.price — the column that no longer exists.
-- This runs BEFORE the DO block below so CASCADE from DROP FUNCTION doesn't
-- fight with a trigger whose function was already dropped here.
DO $$
DECLARE r RECORD;
BEGIN
    FOR r IN
        SELECT t.tgname
        FROM   pg_trigger t
        JOIN   pg_class   c ON c.oid = t.tgrelid
        JOIN   pg_namespace n ON n.oid = c.relnamespace
        WHERE  c.relname   = 'properties'
          AND  n.nspname   = 'public'
          AND  NOT t.tgisinternal
          AND  (t.tgname ILIKE '%price%' OR t.tgname ILIKE '%notify%')
    LOOP
        EXECUTE format('DROP TRIGGER IF EXISTS %I ON public.properties', r.tgname);
        RAISE NOTICE 'Dropped stale trigger on properties: %', r.tgname;
    END LOOP;
END $$;

DO $$
BEGIN
    DROP FUNCTION IF EXISTS is_pro_subscriber(UUID)                               CASCADE;
    DROP FUNCTION IF EXISTS create_price_drop_alert(UUID,UUID,DECIMAL,TEXT)      CASCADE;
    DROP FUNCTION IF EXISTS check_price_drops()                                   CASCADE;
    DROP FUNCTION IF EXISTS log_property_price_change(UUID,DECIMAL,DECIMAL,UUID) CASCADE;
    DROP FUNCTION IF EXISTS get_unread_price_drop_count(UUID)                    CASCADE;
    DROP FUNCTION IF EXISTS get_user_alerts_count(UUID)                          CASCADE;
    DROP FUNCTION IF EXISTS get_active_alerts_count(UUID)                        CASCADE;
    DROP FUNCTION IF EXISTS get_notification_stats(UUID)                         CASCADE;
    DROP FUNCTION IF EXISTS mark_notification_read(UUID,UUID)                    CASCADE;
    DROP FUNCTION IF EXISTS mark_all_notifications_read(UUID)                    CASCADE;
    DROP FUNCTION IF EXISTS trigger_price_change_check()                         CASCADE;
    DROP FUNCTION IF EXISTS notify_price_drop()                                   CASCADE;
    DROP FUNCTION IF EXISTS notify_new_property()                                 CASCADE;
    DROP FUNCTION IF EXISTS cleanup_old_notifications()                           CASCADE;
    DROP FUNCTION IF EXISTS alert_manual_review_sla_breach()                     CASCADE;
    -- Also drop sql4's handle_property_price_change to avoid duplicate triggers
    DROP FUNCTION IF EXISTS handle_property_price_change()                        CASCADE;

    DROP TABLE IF EXISTS message_notification_tracking CASCADE;
    DROP TABLE IF EXISTS notification_property_filters CASCADE;
    DROP TABLE IF EXISTS user_notifications            CASCADE;
    DROP TABLE IF EXISTS notification_queue            CASCADE;
    DROP TABLE IF EXISTS user_notification_preferences CASCADE;
    DROP TABLE IF EXISTS price_drop_alerts             CASCADE;
    DROP TABLE IF EXISTS property_price_history        CASCADE;
    RAISE NOTICE 'Cleanup complete';
END $$;

