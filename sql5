CREATE OR REPLACE FUNCTION is_pro_subscriber(p_user_id UUID)
RETURNS BOOLEAN AS $$
BEGIN
    RETURN EXISTS (
        SELECT 1 FROM user_subscriptions us
        JOIN   subscription_tiers st ON st.id = us.tier_id
        WHERE  us.user_id = p_user_id AND us.status = 'active'
          AND  st.name IN ('pro') AND us.expires_at > NOW()
    );
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE OR REPLACE FUNCTION create_price_drop_alert(
    p_user_id UUID, p_property_id UUID,
    p_target_price DECIMAL DEFAULT NULL, p_alert_type TEXT DEFAULT 'any_drop'
)
RETURNS JSONB AS $$
DECLARE v_alert_id UUID;
BEGIN
    IF NOT is_pro_subscriber(p_user_id) THEN
        RETURN jsonb_build_object('success',false,'error','Price drop alerts require a Pro subscription','upgrade_required',true);
    END IF;
    IF NOT EXISTS (SELECT 1 FROM properties WHERE id=p_property_id AND deleted_at IS NULL) THEN
        RETURN jsonb_build_object('success',false,'error','Property not found');
    END IF;
    INSERT INTO price_drop_alerts (user_id, property_id, target_price, alert_type)
    VALUES (p_user_id, p_property_id, p_target_price, p_alert_type)
    ON CONFLICT (user_id, property_id) DO UPDATE SET
        target_price=EXCLUDED.target_price, alert_type=EXCLUDED.alert_type,
        is_active=TRUE, updated_at=NOW()
    RETURNING id INTO v_alert_id;
    RETURN jsonb_build_object('success',true,'alert_id',v_alert_id);
EXCEPTION WHEN OTHERS THEN RETURN jsonb_build_object('success',false,'error',SQLERRM);
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE OR REPLACE FUNCTION log_property_price_change(
    p_property_id UUID, p_old_price DECIMAL, p_new_price DECIMAL, p_changed_by UUID DEFAULT NULL
)
RETURNS void AS $$
BEGIN
    INSERT INTO property_price_history (property_id, old_price, new_price, changed_by)
    VALUES (p_property_id, p_old_price, p_new_price, p_changed_by);
    PERFORM check_price_drops();
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Fires per-property watch alerts (price_drop_alerts table)
CREATE OR REPLACE FUNCTION check_price_drops()
RETURNS void AS $$
DECLARE r RECORD;
BEGIN
    FOR r IN
        SELECT pda.id AS alert_id, pda.user_id, pda.property_id,
               pda.target_price, pda.alert_threshold, pda.alert_type,
               p.title, p.price AS current_price, pda.last_alerted_price AS old_price
        FROM   price_drop_alerts pda
        JOIN   properties p ON p.id = pda.property_id
        WHERE  pda.is_active = TRUE AND p.deleted_at IS NULL
          AND  (pda.last_alerted_price IS NULL OR p.price < pda.last_alerted_price)
          AND  (
              pda.alert_type = 'any_drop'
              OR (pda.alert_type = 'target_price' AND pda.target_price IS NOT NULL AND p.price <= pda.target_price)
              OR (pda.alert_type = 'percentage' AND pda.last_alerted_price IS NOT NULL
                  AND pda.last_alerted_price > 0
                  AND ((pda.last_alerted_price - p.price) / pda.last_alerted_price * 100) >= pda.alert_threshold)
          )
    LOOP
        INSERT INTO user_notifications (user_id, type, title, message, data, is_read, created_at)
        VALUES (r.user_id, 'price_drop', '💰 Price Drop Alert!',
            'The price for "' || r.title || '" dropped to TZS ' ||
                TO_CHAR(r.current_price, 'FM999,999,999') || '.',
            jsonb_build_object('property_id',r.property_id,'old_price',r.old_price,
                'new_price',r.current_price,'alert_type',r.alert_type,'target_price',r.target_price),
            FALSE, NOW());

        UPDATE price_drop_alerts
        SET    last_alerted_at=NOW(), last_alerted_price=r.current_price, updated_at=NOW()
        WHERE  id = r.alert_id;
    END LOOP;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Fires filter-based alerts (notification_property_filters) AND logs price history
CREATE OR REPLACE FUNCTION notify_price_drop()
RETURNS TRIGGER LANGUAGE plpgsql SECURITY DEFINER AS $$
DECLARE
    v_filter   RECORD;
    v_drop_pct NUMERIC;
BEGIN
    IF NEW.price >= OLD.price THEN RETURN NEW; END IF;

    -- Log the change
    INSERT INTO property_price_history (property_id, old_price, new_price)
    VALUES (NEW.id, OLD.price, NEW.price);

    v_drop_pct := ROUND(((OLD.price - NEW.price) / OLD.price) * 100, 1);
    IF v_drop_pct < 1 THEN RETURN NEW; END IF;

    -- Per-property watch alerts
    PERFORM check_price_drops();

    -- Filter-based alerts
    FOR v_filter IN
        SELECT DISTINCT f.user_id
        FROM   notification_property_filters f
        WHERE  f.notification_category = 'price_change'
          AND  f.is_active = TRUE
          AND  f.user_id  <> COALESCE(NEW.owner_id, '00000000-0000-0000-0000-000000000000'::UUID)
          AND  (f.min_price    IS NULL OR NEW.price                       >= f.min_price)
          AND  (f.max_price    IS NULL OR NEW.price                       <= f.max_price)
          AND  (f.min_bedrooms IS NULL OR COALESCE(NEW.bedrooms,  0)      >= f.min_bedrooms)
          AND  (f.max_bedrooms IS NULL OR COALESCE(NEW.bedrooms,  0)      <= f.max_bedrooms)
          AND  (f.min_bathrooms IS NULL OR COALESCE(NEW.bathrooms,0)      >= f.min_bathrooms)
          AND  (f.max_bathrooms IS NULL OR COALESCE(NEW.bathrooms,0)      <= f.max_bathrooms)
          AND  (f.min_area     IS NULL OR COALESCE(NEW.area,      0)      >= f.min_area)
          AND  (f.max_area     IS NULL OR COALESCE(NEW.area,      0)      <= f.max_area)
          AND  (f.property_types = '{}' OR f.property_types IS NULL OR NEW.category::TEXT = ANY(f.property_types))
    LOOP
        -- Deduplicate: max one filter-based alert per user per property per day
        INSERT INTO user_notifications (user_id, type, title, message, data, is_read)
        SELECT v_filter.user_id, 'price_drop',
            '📉 Price drop ' || v_drop_pct::TEXT || '% — ' || COALESCE(NEW.title,'A property'),
            'Dropped from TZS ' || TO_CHAR(OLD.price,'FM999,999,999') ||
                ' to TZS ' || TO_CHAR(NEW.price,'FM999,999,999'),
            jsonb_build_object('property_id',NEW.id,'old_price',OLD.price,
                'new_price',NEW.price,'drop_pct',v_drop_pct),
            FALSE
        WHERE NOT EXISTS (
            SELECT 1 FROM user_notifications un
            WHERE  un.user_id = v_filter.user_id
              AND  un.type    = 'price_drop'
              AND  un.data->>'property_id' = NEW.id::TEXT
              AND  un.created_at > NOW() - INTERVAL '1 day'
        );
    END LOOP;
    RETURN NEW;
END;
$$;

DROP TRIGGER IF EXISTS on_property_price_update ON properties;
CREATE TRIGGER on_property_price_update
    AFTER UPDATE OF price ON properties FOR EACH ROW
    EXECUTE FUNCTION notify_price_drop();

-- Re-create handle_property_price_change (defined in sql4) here so it survives
-- after sql5's cleanup drops it via CASCADE. Inserts into property_price_changes
-- and notifies users who favorited the property.
CREATE OR REPLACE FUNCTION handle_property_price_change()
RETURNS TRIGGER LANGUAGE plpgsql SECURITY DEFINER AS $$
BEGIN
    IF NEW.price >= OLD.price THEN RETURN NEW; END IF;

    INSERT INTO property_price_changes(property_id, old_price, new_price, changed_by)
    VALUES (NEW.id, OLD.price, NEW.price, auth.uid());

    INSERT INTO user_notifications(user_id, type, title, message, data)
    SELECT
        f.user_id,
        'price_drop',
        'Price Drop on ' || NEW.title,
        'Price dropped from TSh ' || OLD.price::BIGINT::TEXT ||
        ' to TSh ' || NEW.price::BIGINT::TEXT || ' — save ' ||
        ABS(((NEW.price - OLD.price) / OLD.price * 100))::INT::TEXT || '%!',
        jsonb_build_object('property_id', NEW.id, 'old_price', OLD.price, 'new_price', NEW.price)
    FROM favorites f
    WHERE f.property_id = NEW.id
      AND f.user_id != COALESCE(auth.uid(), '00000000-0000-0000-0000-000000000000'::UUID)
    ON CONFLICT DO NOTHING;

    RETURN NEW;
END $$;

DROP TRIGGER IF EXISTS trg_property_price_drop ON properties;
CREATE TRIGGER trg_property_price_drop
    AFTER UPDATE OF price ON properties
    FOR EACH ROW EXECUTE FUNCTION handle_property_price_change();

-- Fires when a new property becomes active — notifies matching subscribers
CREATE OR REPLACE FUNCTION notify_new_property()
RETURNS TRIGGER LANGUAGE plpgsql SECURITY DEFINER AS $$
DECLARE v_filter RECORD;
BEGIN
    IF NEW.status IS DISTINCT FROM 'active' THEN RETURN NEW; END IF;
    IF TG_OP = 'UPDATE' AND OLD.status = 'active' THEN RETURN NEW; END IF;

    FOR v_filter IN
        SELECT DISTINCT f.user_id
        FROM   notification_property_filters f
        WHERE  f.notification_category = 'new_property'
          AND  f.is_active = TRUE
          AND  f.user_id  <> COALESCE(NEW.owner_id,'00000000-0000-0000-0000-000000000000'::UUID)
          AND  (f.min_price    IS NULL OR NEW.price                  >= f.min_price)
          AND  (f.max_price    IS NULL OR NEW.price                  <= f.max_price)
          AND  (f.min_bedrooms IS NULL OR COALESCE(NEW.bedrooms,0)   >= f.min_bedrooms)
          AND  (f.max_bedrooms IS NULL OR COALESCE(NEW.bedrooms,0)   <= f.max_bedrooms)
          AND  (f.min_bathrooms IS NULL OR COALESCE(NEW.bathrooms,0) >= f.min_bathrooms)
          AND  (f.max_bathrooms IS NULL OR COALESCE(NEW.bathrooms,0) <= f.max_bathrooms)
          AND  (f.min_area     IS NULL OR COALESCE(NEW.area,0)       >= f.min_area)
          AND  (f.max_area     IS NULL OR COALESCE(NEW.area,0)       <= f.max_area)
          AND  (f.property_types = '{}' OR f.property_types IS NULL OR NEW.category::TEXT = ANY(f.property_types))
    LOOP
        INSERT INTO user_notifications (user_id, type, title, message, data, is_read)
        VALUES (v_filter.user_id, 'new_property',
            '🏠 New property matching your filter',
            COALESCE(NEW.title,'New property') || ' — TZS ' ||
                TO_CHAR(COALESCE(NEW.price,0),'FM999,999,999'),
            jsonb_build_object('property_id',NEW.id), FALSE);
    END LOOP;
    RETURN NEW;
END;
$$;

DROP TRIGGER IF EXISTS on_new_property_approved ON properties;
CREATE TRIGGER on_new_property_approved
    AFTER INSERT OR UPDATE OF status ON properties FOR EACH ROW
    EXECUTE FUNCTION notify_new_property();

CREATE OR REPLACE FUNCTION get_unread_price_drop_count(p_user_id UUID)
RETURNS INTEGER AS $$
    SELECT COUNT(*)::INTEGER FROM user_notifications
    WHERE user_id=p_user_id AND type='price_drop' AND is_read=FALSE;
$$ LANGUAGE sql SECURITY DEFINER STABLE;

CREATE OR REPLACE FUNCTION get_user_alerts_count(p_user_id UUID)
RETURNS INTEGER AS $$
    SELECT COUNT(*)::INTEGER FROM price_drop_alerts WHERE user_id=p_user_id;
$$ LANGUAGE sql SECURITY DEFINER STABLE;

CREATE OR REPLACE FUNCTION get_active_alerts_count(p_user_id UUID)
RETURNS INTEGER AS $$
    SELECT COUNT(*)::INTEGER FROM price_drop_alerts WHERE user_id=p_user_id AND is_active=TRUE;
$$ LANGUAGE sql SECURITY DEFINER STABLE;

CREATE OR REPLACE FUNCTION get_notification_stats(p_user_id UUID)
RETURNS JSONB AS $$
    SELECT jsonb_build_object(
        'total',              COUNT(*),
        'unread',             COUNT(*) FILTER (WHERE is_read=FALSE),
        'unread_price_drops', COUNT(*) FILTER (WHERE type='price_drop' AND is_read=FALSE),
        'unread_messages',    COUNT(*) FILTER (WHERE type='message'    AND is_read=FALSE),
        'unread_system',      COUNT(*) FILTER (WHERE type='system'     AND is_read=FALSE)
    ) FROM user_notifications WHERE user_id=p_user_id;
$$ LANGUAGE sql SECURITY DEFINER STABLE;

CREATE OR REPLACE FUNCTION mark_notification_read(p_notification_id UUID, p_user_id UUID)
RETURNS BOOLEAN AS $$
DECLARE v_rows INT;
BEGIN
    UPDATE user_notifications SET is_read=TRUE, read_at=NOW()
    WHERE id=p_notification_id AND user_id=p_user_id AND is_read=FALSE;
    GET DIAGNOSTICS v_rows = ROW_COUNT;
    RETURN v_rows > 0;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE OR REPLACE FUNCTION mark_all_notifications_read(p_user_id UUID)
RETURNS INTEGER AS $$
DECLARE v_rows INT;
BEGIN
    UPDATE user_notifications SET is_read=TRUE, read_at=NOW()
    WHERE user_id=p_user_id AND is_read=FALSE;
    GET DIAGNOSTICS v_rows = ROW_COUNT;
    RETURN v_rows;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Deletes read notifications older than 90 days (nightly cleanup)
-- Requires pg_cron extension — enable in: Supabase Dashboard → Database → Extensions → pg_cron
CREATE OR REPLACE FUNCTION cleanup_old_notifications()
RETURNS void LANGUAGE plpgsql SECURITY DEFINER AS $$
DECLARE v_deleted INT;
BEGIN
    DELETE FROM user_notifications WHERE is_read=TRUE AND created_at < NOW() - INTERVAL '90 days';
    GET DIAGNOSTICS v_deleted = ROW_COUNT;
    RAISE NOTICE '[cleanup_old_notifications] Deleted % old notifications at %', v_deleted, NOW();
END;
$$;

-- Alerts admins when manual review items breach the 24-hour SLA (hourly check)
CREATE OR REPLACE FUNCTION alert_manual_review_sla_breach()
RETURNS void LANGUAGE plpgsql SECURITY DEFINER AS $$
DECLARE v_breach_count INTEGER; v_admin RECORD;
BEGIN
    SELECT COUNT(*) INTO v_breach_count FROM manual_review_queue
    WHERE status='pending' AND created_at < NOW() - INTERVAL '24 hours';
    IF v_breach_count = 0 THEN RETURN; END IF;

    FOR v_admin IN SELECT id AS user_id FROM user_profiles WHERE role IN ('admin','super_admin')
    LOOP
        IF NOT EXISTS (
            SELECT 1 FROM user_notifications
            WHERE user_id=v_admin.user_id AND type='system'
              AND data->>'alert_type'='sla_breach'
              AND created_at > NOW() - INTERVAL '4 hours'
        ) THEN
            INSERT INTO user_notifications (user_id, type, title, message, data, is_read)
            VALUES (v_admin.user_id, 'system', '⚠️ Manual Review SLA Breach',
                v_breach_count::TEXT || ' item' ||
                    CASE WHEN v_breach_count>1 THEN 's have' ELSE ' has' END ||
                    ' been pending manual review for over 24 hours.',
                jsonb_build_object('breach_count',v_breach_count,'alert_type','sla_breach'),
                FALSE);
        END IF;
    END LOOP;
END;
$$;

-- Schedule cron jobs (requires pg_cron extension)
-- Enable pg_cron in: Supabase Dashboard → Database → Extensions → pg_cron
