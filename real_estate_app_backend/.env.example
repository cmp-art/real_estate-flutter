# ============================================================
# Makazi Estate — Backend Environment Variables
# ============================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your real values
# 3. NEVER commit .env — it is already in .gitignore
# ============================================================

# ── SERVER ───────────────────────────────────────────────────
PORT=3000
BASE_URL=https://your-backend.up.railway.app

# ── SELCOM CREDENTIALS ───────────────────────────────────────
# Request from: business@selcommobile.com
# Subject: "API Access Request for Subscription Service"
SELCOM_VENDOR=your_vendor_id_here
SELCOM_API_KEY=your_api_key_here
SELCOM_API_SECRET=your_api_secret_here

# ── SUPABASE (service role — server only, NEVER in Flutter app) ──
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
