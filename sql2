CREATE OR REPLACE FUNCTION sync_tier_name()
RETURNS TRIGGER AS $$
BEGIN
    IF TG_OP = 'INSERT' THEN
        SELECT name INTO NEW.tier FROM subscription_tiers WHERE id = NEW.tier_id;
    ELSIF NEW.tier_id IS DISTINCT FROM OLD.tier_id THEN
        SELECT name INTO NEW.tier FROM subscription_tiers WHERE id = NEW.tier_id;
    ELSIF NEW.tier IS DISTINCT FROM OLD.tier THEN
        SELECT id INTO NEW.tier_id FROM subscription_tiers WHERE name = NEW.tier LIMIT 1;
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION create_free_subscription()
RETURNS TRIGGER AS $$
DECLARE v_free_tier_id UUID;
BEGIN
    SELECT id INTO v_free_tier_id FROM subscription_tiers WHERE name='free' LIMIT 1;
    IF v_free_tier_id IS NULL THEN
        RAISE EXCEPTION 'Free tier not found in subscription_tiers table';
    END IF;
    INSERT INTO user_subscriptions (user_id, tier_id, status, started_at, expires_at, auto_renew)
    VALUES (NEW.id, v_free_tier_id, 'active', NOW(), NOW() + INTERVAL '100 years', FALSE)
    ON CONFLICT DO NOTHING;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE OR REPLACE FUNCTION increment_usage(
    p_user_id      UUID,
    p_feature_name TEXT,
    p_date         DATE DEFAULT (NOW() AT TIME ZONE 'UTC')::DATE
)
RETURNS void LANGUAGE plpgsql SECURITY DEFINER SET search_path = public AS $$
BEGIN
    INSERT INTO usage_tracking (user_id, feature_name, usage_count, date, created_at, updated_at, last_used_at)
    VALUES (p_user_id, p_feature_name, 1, p_date, NOW(), NOW(), NOW())
    ON CONFLICT (user_id, feature_name, date) DO UPDATE SET
        usage_count  = usage_tracking.usage_count + 1,
        last_used_at = NOW(),
        updated_at   = NOW();
EXCEPTION WHEN OTHERS THEN
    RAISE WARNING 'Error incrementing usage for user %: %', p_user_id, SQLERRM;
END;
$$;

CREATE OR REPLACE FUNCTION get_current_usage(p_user_id UUID, p_feature_name TEXT)
RETURNS INTEGER AS $$
DECLARE v_count INTEGER;
BEGIN
    SELECT COALESCE(usage_count, 0) INTO v_count
    FROM usage_tracking
    WHERE user_id = p_user_id AND feature_name = p_feature_name AND date = CURRENT_DATE;
    RETURN COALESCE(v_count, 0);
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE OR REPLACE FUNCTION get_usage_history(
    p_user_id UUID, p_feature_name TEXT, p_start_date DATE, p_end_date DATE
)
RETURNS TABLE(date DATE, usage_count INTEGER) AS $$
BEGIN
    RETURN QUERY
    SELECT ut.date, ut.usage_count FROM usage_tracking ut
    WHERE ut.user_id = p_user_id AND ut.feature_name = p_feature_name
      AND ut.date BETWEEN p_start_date AND p_end_date
    ORDER BY ut.date;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE OR REPLACE FUNCTION reset_daily_usage()
RETURNS void AS $$
BEGIN
    DELETE FROM usage_tracking WHERE date < CURRENT_DATE - INTERVAL '30 days';
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE OR REPLACE FUNCTION check_subscription_expiration()
RETURNS void AS $$
BEGIN
    UPDATE user_subscriptions SET status='expired'
    WHERE status='active' AND expires_at < NOW() AND auto_renew = FALSE;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE OR REPLACE FUNCTION update_usage_tracking_timestamps()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at   = NOW();
    NEW.last_used_at = NOW();
    IF TG_OP = 'INSERT' AND NEW.date IS NULL THEN
        NEW.date = (NOW() AT TIME ZONE 'UTC')::DATE;
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Cancel subscription (self-service)
DROP FUNCTION IF EXISTS cancel_user_subscription(UUID,UUID,TEXT) CASCADE;

CREATE OR REPLACE FUNCTION cancel_user_subscription(
    p_subscription_id UUID, p_user_id UUID, p_reason TEXT DEFAULT NULL
)
RETURNS JSONB LANGUAGE plpgsql SECURITY DEFINER SET search_path = public AS $$
DECLARE v_sub user_subscriptions%ROWTYPE;
BEGIN
    SELECT * INTO v_sub FROM user_subscriptions
    WHERE id = p_subscription_id AND user_id = p_user_id AND status = 'active';
    IF NOT FOUND THEN
        RETURN jsonb_build_object('success', false, 'error', 'Active subscription not found');
    END IF;
    UPDATE user_subscriptions SET
        status = 'cancelled', cancelled_at = NOW(), cancelled_by = p_user_id,
        cancellation_reason = p_reason, auto_renew = FALSE, updated_at = NOW()
    WHERE id = p_subscription_id;
    RETURN jsonb_build_object('success', true,
        'message', 'Subscription cancelled. Access continues until expiry date.',
        'expires_at', v_sub.expires_at);
EXCEPTION WHEN OTHERS THEN
    RETURN jsonb_build_object('success', false, 'error', SQLERRM);
END;
$$;

-- ============================================================================
-- CHECK PROPERTY CREATION LIMITS
-- ============================================================================
CREATE OR REPLACE FUNCTION check_property_creation_allowed(
    p_user_id    UUID,
    p_has_video  BOOLEAN DEFAULT FALSE
)
RETURNS JSONB
LANGUAGE plpgsql SECURITY DEFINER SET search_path = public
AS $$
DECLARE
    v_tier         TEXT;
    v_total_props  INTEGER;
    v_max_props    INTEGER;
BEGIN
    -- Get user's active tier
    SELECT st.name INTO v_tier
    FROM   user_subscriptions us
    JOIN   subscription_tiers st ON st.id = us.tier_id
    WHERE  us.user_id = p_user_id AND us.status = 'active'
    LIMIT  1;

    v_tier := COALESCE(v_tier, 'free');

    -- Pro users: unlimited everything
    IF v_tier = 'pro' THEN
        RETURN jsonb_build_object('allowed', true, 'tier', v_tier,
            'reason', NULL, 'current', 0, 'max', -1);
    END IF;

    -- Free users: no video properties allowed
    IF p_has_video THEN
        RETURN jsonb_build_object(
            'allowed', false,
            'tier', v_tier,
            'reason', 'Video properties require a Pro subscription. Upgrade to Pro to add video listings.',
            'current', 0,
            'max', 0,
            'upgrade_required', true
        );
    END IF;

    -- Free users: max 10 image properties (total active, non-deleted)
    SELECT COUNT(*) INTO v_total_props
    FROM   properties
    WHERE  owner_id   = p_user_id
      AND  deleted_at IS NULL;

    v_max_props := 10;

    IF v_total_props >= v_max_props THEN
        RETURN jsonb_build_object(
            'allowed', false,
            'tier', v_tier,
            'reason', 'Free accounts can create up to ' || v_max_props || ' property listings. Upgrade to Pro for unlimited listings.',
            'current', v_total_props,
            'max', v_max_props,
            'upgrade_required', true
        );
    END IF;

    RETURN jsonb_build_object('allowed', true, 'tier', v_tier,
        'reason', NULL, 'current', v_total_props, 'max', v_max_props);
END;
$$;

