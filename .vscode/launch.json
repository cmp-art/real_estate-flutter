{
  // This workspace is opened at the repo root, but the Flutter app lives in the
  // real_estate_app/ subfolder. These configs point the debugger there via cwd.
  // Pick one from the Run and Debug dropdown (Ctrl+Shift+D) and press F5.
  // Requires the "Flutter" + "Dart" VS Code extensions.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Patamjengo — Web (Chrome)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/real_estate_app",
      "program": "lib/main.dart",
      "deviceId": "chrome",
      "args": ["--web-port", "5000"]
    },
    {
      "name": "Patamjengo — Web (Edge)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/real_estate_app",
      "program": "lib/main.dart",
      "deviceId": "edge",
      "args": ["--web-port", "5000"]
    },
    {
      "name": "Patamjengo — Android (debug)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/real_estate_app",
      "program": "lib/main.dart"
    }
  ]
}
