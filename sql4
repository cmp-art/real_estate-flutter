CREATE FUNCTION get_admin_deleted_campaigns(p_limit INT DEFAULT 50, p_offset INT DEFAULT 0)
RETURNS TABLE (id UUID, advertiser_company TEXT, advertiser_email TEXT, campaign_name TEXT,
    total_budget NUMERIC, spent_amount NUMERIC, impressions_count INT, clicks_count INT,
    status TEXT, deleted_at TIMESTAMPTZ, deletion_reason TEXT, created_at TIMESTAMPTZ)
LANGUAGE plpgsql SECURITY DEFINER SET search_path = public AS $$
BEGIN
    RETURN QUERY
    SELECT c.id, a.company_name, a.email, c.campaign_name, c.total_budget, c.spent_amount,
        c.impressions_count, c.clicks_count, c.status, c.deleted_at, c.deletion_reason, c.created_at
