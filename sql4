CREATE VIEW admin_all_accounts WITH (security_invoker = off)
AS
SELECT au.id, au.email, au.created_at AS auth_created_at, au.last_sign_in_at,
    up.full_name, up.phone, up.avatar_url, up.role,
    COALESCE(up.is_active, TRUE) AS is_active,
    COALESCE(up.is_verified, FALSE) AS is_verified,
    up.last_login_at, up.created_at, up.deactivated_at, up.deactivation_reason,
    up.deleted_at, up.deleted_by_admin,
    (SELECT st2.name FROM user_subscriptions s2 JOIN subscription_tiers st2 ON st2.id = s2.tier_id
     WHERE s2.user_id = au.id AND s2.status='active' ORDER BY s2.started_at DESC LIMIT 1) AS current_tier,
    (SELECT COUNT(*) FROM user_subscriptions s3 WHERE s3.user_id = au.id) AS total_subscriptions,
    (SELECT COUNT(*) FROM properties p WHERE p.owner_id = au.id) AS total_properties,
    (SELECT COUNT(*) FROM properties p WHERE p.owner_id = au.id AND p.deleted_at IS NOT NULL) AS deleted_properties,
    (SELECT adv.status FROM advertisers adv WHERE adv.user_id = au.id LIMIT 1) AS advertiser_status,
    (SELECT adv.total_spent FROM advertisers adv WHERE adv.user_id = au.id LIMIT 1) AS advertiser_total_spent,
    CASE WHEN up.deleted_at IS NOT NULL THEN TRUE ELSE FALSE END AS is_deleted
FROM auth.users au LEFT JOIN user_profiles up ON up.id = au.id;

CREATE VIEW admin_all_properties WITH (security_invoker = off)
AS
SELECT p.id, p.owner_id, up.full_name AS owner_name, au.email AS owner_email, up.phone AS owner_phone,
    p.title, p.description, p.property_type, p.price, p.location, p.status,
    p.is_featured, p.is_verified, p.views_count,
    COALESCE(p.images,'{}') AS images, COALESCE(p.videos,'{}') AS videos, COALESCE(p.media_urls,'{}') AS media_urls,
    p.created_at, p.updated_at, p.deleted_at, p.deleted_by_user, p.deleted_by_admin, p.deletion_reason,
    CASE WHEN p.deleted_at IS NOT NULL THEN TRUE ELSE FALSE END AS is_deleted
FROM properties p
LEFT JOIN user_profiles up ON up.id = p.owner_id
LEFT JOIN auth.users    au ON au.id = p.owner_id;

CREATE VIEW admin_active_properties WITH (security_invoker = off)
AS
SELECT p.id, p.owner_id, up.full_name AS owner_name, au.email AS owner_email,
    p.title, p.description, p.property_type, p.price, p.location, p.status,
    p.is_featured, p.is_verified, p.views_count,
    COALESCE(p.images,'{}') AS images, COALESCE(p.videos,'{}') AS videos, COALESCE(p.media_urls,'{}') AS media_urls,
    p.created_at, p.updated_at
FROM properties p
LEFT JOIN user_profiles up ON up.id = p.owner_id
LEFT JOIN auth.users    au ON au.id = p.owner_id
WHERE p.deleted_at IS NULL;

CREATE VIEW admin_all_campaigns WITH (security_invoker = off)
AS
SELECT c.id, c.advertiser_id, a.company_name AS advertiser_company, a.contact_name AS advertiser_contact,
    a.email AS advertiser_email, a.phone AS advertiser_phone, c.campaign_name, c.campaign_objective,
    c.bidding_strategy, c.bid_amount, c.daily_budget, c.total_budget, c.spent_amount,
    c.impressions_count, c.clicks_count, c.conversions_count,
    CASE WHEN c.impressions_count > 0 THEN ROUND((c.clicks_count::NUMERIC/c.impressions_count)*100,4) ELSE 0 END AS ctr_percent,
    c.status, c.start_date, c.end_date, c.target_property_types, c.target_locations,
    c.created_at, c.updated_at, c.deleted_at, c.deleted_by_user, c.deletion_reason,
    CASE WHEN c.deleted_at IS NOT NULL THEN TRUE ELSE FALSE END AS is_deleted
FROM ad_campaigns c LEFT JOIN advertisers a ON a.id = c.advertiser_id;

CREATE VIEW admin_all_creatives WITH (security_invoker = off)
AS
SELECT cr.id, cr.campaign_id, c.campaign_name, c.advertiser_id, a.company_name AS advertiser_company,
    a.email AS advertiser_email, cr.ad_format, cr.headline, cr.description, cr.call_to_action,
    cr.image_url, cr.logo_url, cr.landing_url, cr.video_url, cr.media_type,
    cr.status, cr.is_approved, cr.impressions, cr.clicks, cr.rejection_reason,
    cr.reviewed_by, cr.reviewed_at, cr.created_at, cr.deleted_at, cr.deleted_by_user, cr.deletion_reason,
    CASE WHEN cr.deleted_at IS NOT NULL THEN TRUE ELSE FALSE END AS is_deleted
FROM ad_creatives cr
LEFT JOIN ad_campaigns c ON c.id = cr.campaign_id
LEFT JOIN advertisers  a ON a.id = c.advertiser_id;

CREATE VIEW admin_all_subscriptions WITH (security_invoker = off)
AS
SELECT s.id, s.user_id, up.full_name AS user_full_name, au.email AS user_email, up.phone AS user_phone,
    st.name AS tier_name, st.price AS tier_price, s.status, s.started_at, s.expires_at, s.auto_renew,
    s.payment_provider_id, s.cancelled_at, s.cancelled_by, s.cancellation_reason,
    EXTRACT(YEAR  FROM s.started_at)::INT AS subscription_year,
    EXTRACT(MONTH FROM s.started_at)::INT AS subscription_month,
    EXTRACT(DAY FROM (COALESCE(s.cancelled_at, s.expires_at) - s.started_at))::INT AS active_days,
    s.created_at
FROM user_subscriptions s
LEFT JOIN user_profiles   up ON up.id    = s.user_id
LEFT JOIN auth.users      au ON au.id    = s.user_id
LEFT JOIN subscription_tiers st ON st.id = s.tier_id;

CREATE VIEW admin_ad_revenue_summary WITH (security_invoker = off)
AS
SELECT DATE_TRUNC('month', ai.viewed_at)::DATE AS revenue_month,
    a.company_name AS advertiser, a.email AS advertiser_email, c.campaign_name, c.bidding_strategy,
    COUNT(ai.id) AS impressions, COALESCE(SUM(ai.cost),0) AS impression_revenue_tzs,
    COUNT(ac.id) AS clicks,      COALESCE(SUM(ac.cost),0) AS click_revenue_tzs,
    COALESCE(SUM(ai.cost),0) + COALESCE(SUM(ac.cost),0) AS total_revenue_tzs,
    CASE WHEN c.deleted_at IS NOT NULL THEN TRUE ELSE FALSE END AS campaign_deleted
FROM ad_impressions ai
LEFT JOIN ad_clicks    ac ON ac.impression_id = ai.id
LEFT JOIN ad_campaigns  c ON c.id = ai.campaign_id
LEFT JOIN advertisers   a ON a.id = ai.advertiser_id
GROUP BY DATE_TRUNC('month', ai.viewed_at)::DATE, a.company_name, a.email, c.campaign_name, c.bidding_strategy, c.deleted_at
ORDER BY revenue_month DESC, total_revenue_tzs DESC;

CREATE VIEW admin_subscription_revenue_summary WITH (security_invoker = off)
AS
SELECT DATE_TRUNC('month', s.started_at)::DATE AS revenue_month,
    st.name AS tier, st.price AS tier_price_usd,
    COUNT(s.id) AS new_subscriptions,
    COUNT(s.id) * st.price AS gross_revenue_usd,
    COUNT(s.cancelled_at) FILTER (WHERE s.cancelled_at IS NOT NULL) AS cancellations,
    COUNT(s.id) FILTER (WHERE s.status='active') AS currently_active
FROM user_subscriptions s JOIN subscription_tiers st ON st.id = s.tier_id
GROUP BY DATE_TRUNC('month', s.started_at)::DATE, st.name, st.price
ORDER BY revenue_month DESC, tier;

CREATE VIEW admin_pending_review WITH (security_invoker = off)
AS
SELECT cr.id, cr.campaign_id, c.campaign_name, c.advertiser_id,
    a.company_name AS advertiser_company, a.email AS advertiser_email,
    cr.ad_format, cr.headline, cr.description, cr.call_to_action,
    cr.image_url, cr.logo_url, cr.landing_url, cr.video_url, cr.media_type,
    cr.status, cr.is_approved,
    cr.ai_approved, cr.ai_confidence, cr.ai_category, cr.ai_reviewed_at,
    cr.created_at, cr.deleted_at, cr.deletion_reason,
    c.total_budget, c.daily_budget, c.start_date, c.end_date,
    a.contact_name, a.phone AS advertiser_phone
FROM ad_creatives cr
LEFT JOIN ad_campaigns c ON c.id = cr.campaign_id
LEFT JOIN advertisers  a ON a.id = c.advertiser_id
WHERE cr.is_approved = FALSE AND cr.deleted_at IS NULL AND cr.status NOT IN ('rejected','archived')
ORDER BY cr.created_at ASC;

-- Convenience view: manual review queue items with time-waiting info
-- Used by AdminManualReviewScreen to list items needing human decision
CREATE VIEW admin_pending_manual_reviews WITH (security_invoker = off)
AS
SELECT
    mrq.id,
    mrq.content_type,
    mrq.content_data,
    mrq.submitted_by,
    u.email  AS submitter_email,
    up.full_name AS submitter_name,
    mrq.status,
    mrq.reviewed_by,
    mrq.review_note,
    mrq.reviewed_at,
    mrq.created_at,
    EXTRACT(EPOCH FROM (NOW() - mrq.created_at)) / 3600 AS hours_waiting
FROM manual_review_queue mrq
LEFT JOIN auth.users  u  ON u.id  = mrq.submitted_by
LEFT JOIN user_profiles up ON up.id = mrq.submitted_by
WHERE mrq.status = 'pending'
ORDER BY mrq.created_at ASC;

CREATE VIEW admin_dashboard_stats WITH (security_invoker = off)
AS
SELECT
    (SELECT COUNT(*) FROM auth.users)                                          AS total_users,
    (SELECT COUNT(*) FROM auth.users WHERE created_at > NOW()-INTERVAL '30 days') AS new_users_30d,
    (SELECT COUNT(*) FROM user_profiles WHERE is_active=TRUE)                  AS active_users,
    (SELECT COUNT(*) FROM user_profiles WHERE role IN ('admin','super_admin','moderator')) AS total_admins,
    (SELECT COUNT(*) FROM advertisers)                                          AS total_advertisers,
    (SELECT COUNT(*) FROM ad_campaigns WHERE status='running')                  AS active_campaigns,
    (SELECT COUNT(*) FROM ad_creatives WHERE is_approved=FALSE AND status!='rejected' AND deleted_at IS NULL) AS pending_ads,
    (SELECT COUNT(*) FROM manual_review_queue WHERE status='pending')                   AS pending_manual_reviews,
    (SELECT COALESCE(SUM(account_balance),0) FROM advertisers)                  AS total_advertiser_balance,
    (SELECT COALESCE(SUM(total_spent),0) FROM advertisers)                      AS total_ad_revenue,
    (SELECT COUNT(*) FROM admin_activity_log WHERE created_at > NOW()-INTERVAL '24 hours') AS admin_actions_24h,
    (SELECT COUNT(*) FROM properties WHERE deleted_at IS NULL)                  AS total_properties,
    (SELECT COUNT(*) FROM user_subscriptions WHERE status='active')             AS active_subscriptions;

