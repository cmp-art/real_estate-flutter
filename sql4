-- ── USER SELF-DELETE PROPERTY ─────────────────────────────────────────────────
-- Called by the app when a property owner deletes their own listing.
-- Sets deleted_by_user=TRUE so admins can distinguish user-initiated deletes
-- from admin-initiated deletes and filter them separately in the dashboard.
DROP FUNCTION IF EXISTS user_delete_property(UUID);
CREATE FUNCTION user_delete_property(p_property_id UUID)
RETURNS JSONB LANGUAGE plpgsql SECURITY DEFINER SET search_path = public AS $$
DECLARE
    v_user_id UUID := auth.uid();
    v_prop    properties%ROWTYPE;
BEGIN
    SELECT * INTO v_prop FROM properties WHERE id = p_property_id;
    IF NOT FOUND THEN
        RETURN jsonb_build_object('success', false, 'error', 'Property not found');
    END IF;
    IF v_prop.owner_id != v_user_id THEN
        RETURN jsonb_build_object('success', false, 'error', 'Not authorized');
    END IF;
    IF v_prop.deleted_at IS NOT NULL THEN
        RETURN jsonb_build_object('success', false, 'error', 'Property already deleted');
    END IF;
    UPDATE properties SET
        deleted_at      = NOW(),
        deleted_by_user = TRUE,
        status          = 'deleted',
        updated_at      = NOW()
    WHERE id = p_property_id;
    RETURN jsonb_build_object('success', true, 'message', 'Property deleted');
END;
$$;

