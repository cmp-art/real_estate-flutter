-- Backfill FREE SUBSCRIPTIONS for ALL existing users who have no active subscription
-- This fixes "No active subscription found" for users created before this system was set up
-- Without a subscription row, Flutter cannot determine tier → shows 0 ads
DO $$
DECLARE v_free_tier_id UUID;
BEGIN
    SELECT id INTO v_free_tier_id FROM subscription_tiers WHERE name = 'free' LIMIT 1;
    IF v_free_tier_id IS NOT NULL THEN
        INSERT INTO user_subscriptions (user_id, tier_id, status, started_at, expires_at, auto_renew)
        SELECT au.id, v_free_tier_id, 'active', NOW(), NOW() + INTERVAL '100 years', FALSE
        FROM auth.users au
        WHERE NOT EXISTS (
            SELECT 1 FROM user_subscriptions us
            WHERE us.user_id = au.id AND us.status = 'active'
        )
        ON CONFLICT DO NOTHING;
        RAISE NOTICE '✅ Free subscriptions backfilled for existing users';
    ELSE
        RAISE WARNING '⚠️  Free tier not found — run 02_subscription_payment_system.sql first';
    END IF;
END $$;

