CREATE FUNCTION admin_soft_delete_creative(p_creative_id UUID, p_admin_id UUID, p_reason TEXT DEFAULT NULL)
RETURNS JSONB LANGUAGE plpgsql SECURITY DEFINER SET search_path = public AS $$
DECLARE v_advertiser_id UUID; v_headline TEXT; v_campaign_id UUID; v_campaign_name TEXT;
        v_user_id UUID; v_admin_email TEXT; v_admin_role TEXT; v_notif_id UUID;
BEGIN
    SELECT ac.headline, ac.campaign_id, camp.campaign_name, camp.advertiser_id
    INTO v_headline, v_campaign_id, v_campaign_name, v_advertiser_id
    FROM ad_creatives ac JOIN ad_campaigns camp ON camp.id=ac.campaign_id WHERE ac.id=p_creative_id;
    IF v_headline IS NULL THEN RETURN jsonb_build_object('success',false,'error','Ad creative not found'); END IF;
    IF (SELECT deleted_at FROM ad_creatives WHERE id=p_creative_id) IS NOT NULL THEN
        RETURN jsonb_build_object('success',false,'error','Ad is already deleted'); END IF;
    SELECT user_id INTO v_user_id FROM advertisers WHERE id=v_advertiser_id;
    SELECT COALESCE(email,'admin@system') INTO v_admin_email FROM auth.users WHERE id=p_admin_id;
    SELECT COALESCE(role,'admin') INTO v_admin_role FROM user_profiles WHERE id=p_admin_id;
    UPDATE ad_creatives SET deleted_at=NOW(), deletion_reason=p_reason, status='archived',
        is_approved=FALSE, updated_at=NOW() WHERE id=p_creative_id;
    UPDATE ad_campaigns SET status='paused', updated_at=NOW() WHERE id=v_campaign_id
        AND NOT EXISTS (SELECT 1 FROM ad_creatives WHERE campaign_id=v_campaign_id AND deleted_at IS NULL AND status IN ('active','paused'));
    IF v_user_id IS NOT NULL THEN
        INSERT INTO user_notifications (user_id,type,title,message,data,is_read,created_at)
        VALUES (v_user_id,'ad_removed','Your ad has been removed',
            CASE WHEN p_reason IS NOT NULL AND p_reason<>'' THEN 'Your ad "'||v_headline||'" removed. Reason: '||p_reason
                 ELSE 'Your ad "'||v_headline||'" has been removed by an administrator.' END,
            jsonb_build_object('creative_id',p_creative_id,'campaign_id',v_campaign_id,'reason',p_reason,'action','ad_removed'),
            FALSE, NOW()) RETURNING id INTO v_notif_id;
    END IF;
    INSERT INTO admin_activity_log (admin_id,admin_email,admin_role,action,target_type,target_id,description,metadata,created_at)
    VALUES (p_admin_id,v_admin_email,v_admin_role,'delete_creative','ad_creative',p_creative_id,
        'Deleted ad: '||v_headline, jsonb_build_object('reason',p_reason,'campaign_id',v_campaign_id,'notification_id',v_notif_id), NOW());
    RETURN jsonb_build_object('success',true,'message','Ad removed and advertiser notified','notification_sent',v_notif_id IS NOT NULL);
EXCEPTION WHEN OTHERS THEN RETURN jsonb_build_object('success',false,'error',SQLERRM,'detail',SQLSTATE);
END; $$;

