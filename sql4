CREATE FUNCTION get_admin_cancelled_subscriptions(p_limit INT DEFAULT 50, p_offset INT DEFAULT 0)
RETURNS TABLE (id UUID, user_email TEXT, user_full_name TEXT, tier_name TEXT, tier_price NUMERIC,
    started_at TIMESTAMPTZ, cancelled_at TIMESTAMPTZ, cancellation_reason TEXT, active_days INT)
LANGUAGE plpgsql SECURITY DEFINER SET search_path = public AS $$
BEGIN
    RETURN QUERY
    SELECT s.id, au.email, up.full_name, st.name, st.price, s.started_at, s.cancelled_at,
        s.cancellation_reason, EXTRACT(DAY FROM (s.cancelled_at-s.started_at))::INT
    FROM user_subscriptions s
    JOIN subscription_tiers st ON st.id=s.tier_id
    LEFT JOIN user_profiles up ON up.id=s.user_id
    LEFT JOIN auth.users    au ON au.id=s.user_id
    WHERE s.status='cancelled' ORDER BY s.cancelled_at DESC LIMIT p_limit OFFSET p_offset;
END; $$;

