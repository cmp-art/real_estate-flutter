-- NOTE: user_profiles RLS was already applied at the TOP of this file
-- (Priority Zero block) to guarantee it runs even if later statements fail.
-- We only need to handle admin_activity_log and other tables here.

ALTER TABLE user_profiles      ENABLE ROW LEVEL SECURITY;
ALTER TABLE admin_activity_log ENABLE ROW LEVEL SECURITY;

-- Verify user_profiles has exactly the correct policies (re-apply if somehow missing)
DO $$
DECLARE
    pol RECORD;
BEGIN
    -- Only recreate if the safe policy is somehow missing
    IF NOT EXISTS (
        SELECT 1 FROM pg_policies
        WHERE tablename = 'user_profiles'
        AND policyname = 'Public can view user profiles'
        AND schemaname = 'public'
    ) THEN
        -- Nuke everything and reapply
        FOR pol IN SELECT policyname FROM pg_policies WHERE tablename='user_profiles' AND schemaname='public'
        LOOP
            EXECUTE format('DROP POLICY IF EXISTS %I ON public.user_profiles', pol.policyname);
        END LOOP;
        CREATE POLICY "Public can view user profiles" ON public.user_profiles FOR SELECT TO public USING (TRUE);
        CREATE POLICY "Users can update own profile"  ON public.user_profiles FOR UPDATE TO authenticated USING (auth.uid() = id) WITH CHECK (auth.uid() = id);
        CREATE POLICY "Users can insert own profile"  ON public.user_profiles FOR INSERT TO authenticated WITH CHECK (auth.uid() = id);
        CREATE POLICY "Service role full access"      ON public.user_profiles FOR ALL   TO service_role  USING (TRUE) WITH CHECK (TRUE);
        RAISE NOTICE 'Re-applied user_profiles RLS policies';
    ELSE
        RAISE NOTICE '✅ user_profiles RLS policies already in place';
    END IF;
END $$;

