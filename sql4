-- ============================================================================
-- PART 10: PROPERTIES_WITH_TIER VIEW
-- Used by the Flutter app's PropertyRemoteDataSource to order listings by
-- owner subscription tier (pro → basic → free) without a function-in-select.
-- Depends on: properties, user_subscriptions, subscription_tiers (all above).
-- ============================================================================

DROP VIEW IF EXISTS properties_with_tier;

CREATE VIEW properties_with_tier WITH (security_invoker = off) AS
SELECT
    p.*,
    CASE
        WHEN st.name = 'pro' THEN 1
        ELSE                      2   -- free or no active subscription
    END AS owner_tier_rank
FROM properties p
LEFT JOIN user_subscriptions us
    ON  us.user_id = p.owner_id
    AND us.status  = 'active'
LEFT JOIN subscription_tiers st
    ON  st.id = us.tier_id;

GRANT SELECT ON properties_with_tier TO authenticated, anon, service_role;

NOTIFY pgrst, 'reload schema';

-- ============================================================================
-- PART 11: PROPERTY_LIST_VIEW (APP'S MAIN VIEW)
-- Optimized view for property list queries - returns only thumbnail instead
-- of full images array to reduce bandwidth by 80%+
-- ============================================================================

DROP VIEW IF EXISTS property_list_view CASCADE;

CREATE VIEW property_list_view WITH (security_invoker = off) AS
SELECT 
    p.id,
    p.title,
    p.description,
    p.price,
    p.type,
    p.category,
    p.location,
    p.latitude,
    p.longitude,
    p.bedrooms,
    p.bathrooms,
    p.area,
    p.images[1] as thumbnail_url,
    array_length(p.images, 1) as total_images,
    p.owner_id,
    p.status,
    p.is_featured,
    p.views_count,
    p.created_at,
    p.updated_at,
    CASE 
        WHEN st.name = 'pro' THEN 1 
        ELSE 2 
    END AS owner_tier_rank,
    p.images,
    p.videos,
    p.property_type,
    p.deleted_at,
    COALESCE(up.full_name, au.email, 'Unknown Owner') as owner_name,
    up.avatar_url as owner_avatar,
    p.rent_duration
FROM properties p
LEFT JOIN user_subscriptions us ON us.user_id = p.owner_id AND us.status = 'active'
LEFT JOIN subscription_tiers st ON st.id = us.tier_id
LEFT JOIN user_profiles up ON up.id = p.owner_id
LEFT JOIN auth.users au ON au.id = p.owner_id;

GRANT SELECT ON property_list_view TO authenticated, anon, service_role;



