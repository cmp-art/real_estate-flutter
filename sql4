-- ADMIN AD CREATIVE APPROVE / REJECT
-- ============================================================================
DROP FUNCTION IF EXISTS admin_approve_creative(UUID, UUID);
DROP FUNCTION IF EXISTS admin_reject_creative(UUID, UUID, TEXT);

CREATE FUNCTION admin_approve_creative(
    p_creative_id UUID,
    p_admin_id    UUID
)
RETURNS JSONB
LANGUAGE plpgsql SECURITY DEFINER SET search_path = public
AS $$
DECLARE
    v_headline      TEXT;
    v_campaign_id   UUID;
    v_advertiser_id UUID;
    v_user_id       UUID;
    v_admin_email   TEXT;
    v_admin_role    TEXT;
BEGIN
    IF NOT is_admin(p_admin_id) THEN
        RETURN jsonb_build_object('success', false, 'error', 'Not authorized');
    END IF;

    SELECT cr.headline, cr.campaign_id, c.advertiser_id
    INTO   v_headline, v_campaign_id, v_advertiser_id
    FROM   ad_creatives cr
    JOIN   ad_campaigns  c ON c.id = cr.campaign_id
    WHERE  cr.id = p_creative_id AND cr.deleted_at IS NULL;

    IF v_headline IS NULL THEN
        RETURN jsonb_build_object('success', false, 'error', 'Creative not found');
    END IF;

    SELECT COALESCE(email,'admin@system') INTO v_admin_email FROM auth.users WHERE id = p_admin_id;
    SELECT COALESCE(role,'admin')         INTO v_admin_role  FROM user_profiles WHERE id = p_admin_id;
    SELECT user_id INTO v_user_id FROM advertisers WHERE id = v_advertiser_id;

    -- Approve creative and set active in one statement
    UPDATE ad_creatives
    SET    is_approved = TRUE,
           status      = 'active',
           updated_at  = NOW()
    WHERE  id = p_creative_id;

    -- Start the campaign immediately (no status restriction)
    UPDATE ad_campaigns
    SET    status     = 'running',
           updated_at = NOW()
    WHERE  id         = v_campaign_id
      AND  deleted_at IS NULL;

    -- Notify advertiser
    IF v_user_id IS NOT NULL THEN
        INSERT INTO user_notifications (user_id, type, title, message, data, is_read, created_at)
        VALUES (v_user_id, 'ad_approved', '✅ Your ad has been approved',
            'Your ad "' || v_headline || '" has been approved and is now live!',
            jsonb_build_object('creative_id', p_creative_id, 'campaign_id', v_campaign_id, 'action', 'ad_approved'),
            FALSE, NOW());
    END IF;

    INSERT INTO admin_activity_log (admin_id, admin_email, admin_role, action, target_type, target_id, description)
    VALUES (p_admin_id, v_admin_email, v_admin_role, 'approve_creative', 'ad_creative', p_creative_id,
            'Approved ad: ' || v_headline);

    RETURN jsonb_build_object('success', true, 'message', 'Ad approved and now live');
EXCEPTION WHEN OTHERS THEN
    RETURN jsonb_build_object('success', false, 'error', SQLERRM);
END;
$$;

CREATE FUNCTION admin_reject_creative(
    p_creative_id UUID,
    p_admin_id    UUID,
    p_reason      TEXT DEFAULT NULL
)
RETURNS JSONB
LANGUAGE plpgsql SECURITY DEFINER SET search_path = public
AS $$
DECLARE
    v_headline      TEXT;
    v_campaign_id   UUID;
    v_advertiser_id UUID;
    v_user_id       UUID;
    v_admin_email   TEXT;
    v_admin_role    TEXT;
BEGIN
    IF NOT is_admin(p_admin_id) THEN
        RETURN jsonb_build_object('success', false, 'error', 'Not authorized');
    END IF;

    SELECT cr.headline, cr.campaign_id, c.advertiser_id
    INTO   v_headline, v_campaign_id, v_advertiser_id
    FROM   ad_creatives cr
    JOIN   ad_campaigns  c ON c.id = cr.campaign_id
    WHERE  cr.id = p_creative_id AND cr.deleted_at IS NULL;

    IF v_headline IS NULL THEN
        RETURN jsonb_build_object('success', false, 'error', 'Creative not found');
    END IF;

    SELECT COALESCE(email,'admin@system') INTO v_admin_email FROM auth.users WHERE id = p_admin_id;
    SELECT COALESCE(role,'admin')         INTO v_admin_role  FROM user_profiles WHERE id = p_admin_id;
    SELECT user_id INTO v_user_id FROM advertisers WHERE id = v_advertiser_id;

    UPDATE ad_creatives
    SET    is_approved      = FALSE,
           status           = 'rejected',
           rejection_reason = p_reason,
           updated_at       = NOW()
    WHERE  id = p_creative_id;

    IF v_user_id IS NOT NULL THEN
        INSERT INTO user_notifications (user_id, type, title, message, data, is_read, created_at)
        VALUES (v_user_id, 'ad_rejected', 'Your ad was not approved',
            'Your ad "' || v_headline || '" was not approved.' || COALESCE(' Reason: ' || p_reason, ''),
            jsonb_build_object('creative_id', p_creative_id, 'reason', p_reason, 'action', 'ad_rejected'),
            FALSE, NOW());
    END IF;

    INSERT INTO admin_activity_log (admin_id, admin_email, admin_role, action, target_type, target_id, description)
    VALUES (p_admin_id, v_admin_email, v_admin_role, 'reject_creative', 'ad_creative', p_creative_id,
            'Rejected ad: ' || v_headline || COALESCE('. Reason: ' || p_reason, ''));

    RETURN jsonb_build_object('success', true, 'message', 'Ad rejected');
EXCEPTION WHEN OTHERS THEN
    RETURN jsonb_build_object('success', false, 'error', SQLERRM);
END;
$$;

