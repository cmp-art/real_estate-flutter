CREATE FUNCTION admin_feature_property(p_property_id UUID, p_admin_id UUID, p_featured BOOLEAN)
RETURNS JSONB LANGUAGE plpgsql SECURITY DEFINER SET search_path = public AS $$
DECLARE v_prop properties%ROWTYPE; v_admin_email TEXT; v_admin_role TEXT;
BEGIN
    SELECT * INTO v_prop FROM properties WHERE id=p_property_id AND deleted_at IS NULL;
    IF NOT FOUND THEN RETURN jsonb_build_object('success',false,'error','Property not found'); END IF;
    SELECT COALESCE(email,'admin@system') INTO v_admin_email FROM auth.users WHERE id=p_admin_id;
    SELECT COALESCE(role,'admin') INTO v_admin_role FROM user_profiles WHERE id=p_admin_id;
    UPDATE properties SET is_featured=p_featured, updated_at=NOW() WHERE id=p_property_id;
    INSERT INTO user_notifications (user_id,type,title,message,data,is_read,created_at)
    VALUES (v_prop.owner_id,
        CASE WHEN p_featured THEN 'property_featured' ELSE 'property_unfeatured' END,
        CASE WHEN p_featured THEN '🌟 Your property is now featured!' ELSE 'Property feature removed' END,
        CASE WHEN p_featured THEN 'Your listing "'||v_prop.title||'" has been featured!'
             ELSE 'Your listing "'||v_prop.title||'" is no longer featured.' END,
        jsonb_build_object('property_id',p_property_id,'is_featured',p_featured), FALSE, NOW());
    INSERT INTO admin_activity_log (admin_id,admin_email,admin_role,action,target_type,target_id,description)
    VALUES (p_admin_id,v_admin_email,v_admin_role,
        CASE WHEN p_featured THEN 'feature_property' ELSE 'unfeature_property' END,
        'property',p_property_id,
        CASE WHEN p_featured THEN 'Property featured' ELSE 'Property unfeatured' END);
    RETURN jsonb_build_object('success',true);
EXCEPTION WHEN OTHERS THEN RETURN jsonb_build_object('success',false,'error',SQLERRM);
END; $$;

CREATE FUNCTION admin_verify_property(p_property_id UUID, p_admin_id UUID, p_verified BOOLEAN)
RETURNS JSONB LANGUAGE plpgsql SECURITY DEFINER SET search_path = public AS $$
DECLARE v_prop properties%ROWTYPE; v_admin_email TEXT; v_admin_role TEXT;
BEGIN
    SELECT * INTO v_prop FROM properties WHERE id=p_property_id AND deleted_at IS NULL;
    IF NOT FOUND THEN RETURN jsonb_build_object('success',false,'error','Property not found'); END IF;
    SELECT COALESCE(email,'admin@system') INTO v_admin_email FROM auth.users WHERE id=p_admin_id;
    SELECT COALESCE(role,'admin') INTO v_admin_role FROM user_profiles WHERE id=p_admin_id;
    UPDATE properties SET is_verified=p_verified, moderated_by=p_admin_id, moderated_at=NOW(), updated_at=NOW() WHERE id=p_property_id;
    INSERT INTO user_notifications (user_id,type,title,message,data,is_read,created_at)
    VALUES (v_prop.owner_id,
        CASE WHEN p_verified THEN 'property_verified' ELSE 'property_unverified' END,
        CASE WHEN p_verified THEN '✅ Property verified!' ELSE 'Property verification removed' END,
        CASE WHEN p_verified THEN 'Your listing "'||v_prop.title||'" has been verified!'
             ELSE 'The verified status for "'||v_prop.title||'" has been removed.' END,
        jsonb_build_object('property_id',p_property_id,'is_verified',p_verified), FALSE, NOW());
    INSERT INTO admin_activity_log (admin_id,admin_email,admin_role,action,target_type,target_id,description)
    VALUES (p_admin_id,v_admin_email,v_admin_role,
        CASE WHEN p_verified THEN 'verify_property' ELSE 'unverify_property' END,
        'property',p_property_id,
        CASE WHEN p_verified THEN 'Property verified' ELSE 'Property unverified' END);
    RETURN jsonb_build_object('success',true);
EXCEPTION WHEN OTHERS THEN RETURN jsonb_build_object('success',false,'error',SQLERRM);
END; $$;

CREATE FUNCTION admin_delete_property_media(p_property_id UUID, p_admin_id UUID, p_media_url TEXT, p_reason TEXT DEFAULT NULL)
RETURNS JSONB LANGUAGE plpgsql SECURITY DEFINER SET search_path = public AS $$
DECLARE v_prop properties%ROWTYPE; v_admin_email TEXT; v_admin_role TEXT;
BEGIN
    SELECT * INTO v_prop FROM properties WHERE id=p_property_id;
    IF NOT FOUND THEN RETURN jsonb_build_object('success',false,'error','Property not found'); END IF;
    SELECT COALESCE(email,'admin@system') INTO v_admin_email FROM auth.users WHERE id=p_admin_id;
    SELECT COALESCE(role,'admin') INTO v_admin_role FROM user_profiles WHERE id=p_admin_id;
    UPDATE properties SET
        images     = array_remove(COALESCE(images,'{}'),p_media_url),
        videos     = array_remove(COALESCE(videos,'{}'),p_media_url),
        media_urls = array_remove(COALESCE(media_urls,'{}'),p_media_url),
        updated_at = NOW()
    WHERE id=p_property_id;
    INSERT INTO user_notifications (user_id,type,title,message,data,is_read,created_at)
    VALUES (v_prop.owner_id,'property_media_removed','Media removed from your listing',
        'A photo/video was removed from "'||v_prop.title||'". Reason: '||COALESCE(p_reason,'Policy violation'),
        jsonb_build_object('property_id',p_property_id,'media_url',p_media_url,'reason',p_reason), FALSE, NOW());
    INSERT INTO admin_activity_log (admin_id,admin_email,admin_role,action,target_type,target_id,description,metadata)
    VALUES (p_admin_id,v_admin_email,v_admin_role,'delete_property_media','property',p_property_id,
        COALESCE(p_reason,'Media removed'), jsonb_build_object('media_url',p_media_url));
    RETURN jsonb_build_object('success',true);
EXCEPTION WHEN OTHERS THEN RETURN jsonb_build_object('success',false,'error',SQLERRM);
END; $$;

CREATE FUNCTION get_admin_archive_stats()
RETURNS JSONB LANGUAGE plpgsql SECURITY DEFINER SET search_path = public AS $$
DECLARE v_result JSONB;
BEGIN
    SELECT jsonb_build_object(
        'total_accounts',          (SELECT COUNT(*) FROM auth.users),
        'active_accounts',         (SELECT COUNT(*) FROM user_profiles WHERE is_active=TRUE AND deleted_at IS NULL),
        'deactivated_accounts',    (SELECT COUNT(*) FROM user_profiles WHERE is_active=FALSE),
        'deleted_accounts',        (SELECT COUNT(*) FROM user_profiles WHERE deleted_at IS NOT NULL),
        'total_subscriptions',     (SELECT COUNT(*) FROM user_subscriptions),
        'active_subscriptions',    (SELECT COUNT(*) FROM user_subscriptions WHERE status='active'),
        'cancelled_subscriptions', (SELECT COUNT(*) FROM user_subscriptions WHERE status='cancelled'),
        'expired_subscriptions',   (SELECT COUNT(*) FROM user_subscriptions WHERE status='expired'),
        'total_properties',        (SELECT COUNT(*) FROM properties),
        'active_properties',       (SELECT COUNT(*) FROM properties WHERE deleted_at IS NULL),
        'deleted_properties',      (SELECT COUNT(*) FROM properties WHERE deleted_at IS NOT NULL),
        'total_campaigns',         (SELECT COUNT(*) FROM ad_campaigns),
        'active_campaigns',        (SELECT COUNT(*) FROM ad_campaigns WHERE status='running' AND deleted_at IS NULL),
        'deleted_campaigns',       (SELECT COUNT(*) FROM ad_campaigns WHERE deleted_at IS NOT NULL),
        'total_creatives',         (SELECT COUNT(*) FROM ad_creatives),
        'deleted_creatives',       (SELECT COUNT(*) FROM ad_creatives WHERE deleted_at IS NOT NULL),
        'pending_approval',        (SELECT COUNT(*) FROM ad_creatives WHERE is_approved=FALSE AND deleted_at IS NULL AND status!='rejected'),
        'total_impression_revenue_tzs', (SELECT COALESCE(SUM(cost),0) FROM ad_impressions),
