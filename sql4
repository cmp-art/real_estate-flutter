CREATE OR REPLACE FUNCTION create_user_profile()
RETURNS TRIGGER AS $$
BEGIN
    INSERT INTO user_profiles (id, full_name, email, role, email_verified, created_at)
    VALUES (NEW.id, COALESCE(NEW.raw_user_meta_data->>'full_name', NEW.email), NEW.email, 'user',
            NEW.email_confirmed_at IS NOT NULL, NOW())
    ON CONFLICT (id) DO NOTHING;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE OR REPLACE FUNCTION protect_user_role()
RETURNS TRIGGER AS $$
BEGIN
    IF (OLD.role IS DISTINCT FROM NEW.role) AND NOT is_admin(auth.uid()) THEN
        NEW.role := OLD.role;
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- NOTE: on_auth_user_created is also used by File 2 for free subscription.
-- We recreate it here to call BOTH functions via a wrapper.
DROP TRIGGER IF EXISTS on_auth_user_created ON auth.users;
CREATE OR REPLACE FUNCTION on_new_user_handler()
RETURNS TRIGGER AS $$
DECLARE
    v_free_tier_id UUID;
    v_full_name    TEXT;
    v_avatar_url   TEXT;
BEGIN
    -- ── Extract name & avatar from metadata ───────────────────────────────────
    -- Google OAuth stores name as 'name' or 'full_name', avatar as 'avatar_url' or 'picture'
    -- Email sign-up stores name as 'full_name'
    -- We check all possible keys so BOTH methods produce identical profile rows.
    v_full_name := COALESCE(
        NEW.raw_user_meta_data->>'full_name',   -- email sign-up
        NEW.raw_user_meta_data->>'name',         -- Google OAuth
        NEW.email,                               -- fallback: email address
        'User'
    );

    v_avatar_url := COALESCE(
        NEW.raw_user_meta_data->>'avatar_url',   -- email sign-up (if provided)
        NEW.raw_user_meta_data->>'picture'        -- Google OAuth
    );

    -- ── 1. Create user profile ────────────────────────────────────────────────
    -- ON CONFLICT DO UPDATE ensures Google re-logins update the avatar/name
    INSERT INTO user_profiles (id, full_name, email, avatar_url, role, email_verified, created_at, updated_at)
    VALUES (
        NEW.id,
        v_full_name,
        NEW.email,
        v_avatar_url,
        'user',
        NEW.email_confirmed_at IS NOT NULL,
        NOW(),
        NOW()
    )
    ON CONFLICT (id) DO UPDATE SET
        full_name      = COALESCE(EXCLUDED.full_name, user_profiles.full_name),
        email          = COALESCE(EXCLUDED.email, user_profiles.email),
        avatar_url     = COALESCE(EXCLUDED.avatar_url, user_profiles.avatar_url),
        email_verified = EXCLUDED.email_verified,
        updated_at     = NOW();

    -- ── 2. Create free subscription ───────────────────────────────────────────
    SELECT id INTO v_free_tier_id FROM subscription_tiers WHERE name = 'free' LIMIT 1;
    IF v_free_tier_id IS NOT NULL THEN
        INSERT INTO user_subscriptions (user_id, tier_id, status, started_at, expires_at, auto_renew)
        VALUES (NEW.id, v_free_tier_id, 'active', NOW(), NOW() + INTERVAL '100 years', FALSE)
        ON CONFLICT DO NOTHING;
    END IF;

    -- ── 3. Create advertiser record ───────────────────────────────────────────
    INSERT INTO advertisers (user_id, company_name, contact_name, email, phone, company_type, status)
    VALUES (
        NEW.id,
        v_full_name,
        v_full_name,
        COALESCE(NEW.email, 'noreply@example.com'),
        'N/A',
        'real_estate_agency',
        'active'
    )
    ON CONFLICT (user_id) DO NOTHING;

    RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE TRIGGER on_auth_user_created
    AFTER INSERT ON auth.users FOR EACH ROW
    EXECUTE FUNCTION on_new_user_handler();

DROP TRIGGER IF EXISTS ensure_role_protection ON user_profiles;
CREATE TRIGGER ensure_role_protection
    BEFORE UPDATE ON user_profiles FOR EACH ROW
    EXECUTE FUNCTION protect_user_role();

