    ON content_appeals FOR SELECT TO authenticated
    USING (auth.uid() = submitted_by OR is_admin(auth.uid()));

CREATE POLICY "Admins manage all appeals"
    ON content_appeals FOR UPDATE TO authenticated
    USING (is_admin(auth.uid()));

