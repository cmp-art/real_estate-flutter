CREATE FUNCTION admin_soft_delete_property_with_notify(p_property_id UUID, p_admin_id UUID, p_reason TEXT DEFAULT NULL)
RETURNS JSONB LANGUAGE plpgsql SECURITY DEFINER SET search_path = public AS $$
DECLARE v_owner_id UUID; v_title TEXT; v_admin_email TEXT; v_admin_role TEXT; v_notif_id UUID;
BEGIN
    SELECT owner_id, title INTO v_owner_id, v_title FROM properties WHERE id = p_property_id;
    IF v_owner_id IS NULL THEN RETURN jsonb_build_object('success',false,'error','Property not found'); END IF;
    IF (SELECT deleted_at FROM properties WHERE id=p_property_id) IS NOT NULL THEN
        RETURN jsonb_build_object('success',false,'error','Property is already deleted'); END IF;
    SELECT COALESCE(email,'admin@system') INTO v_admin_email FROM auth.users WHERE id=p_admin_id;
    SELECT COALESCE(role,'admin') INTO v_admin_role FROM user_profiles WHERE id=p_admin_id;
    UPDATE properties SET deleted_at=NOW(), deleted_by_admin=p_admin_id, deletion_reason=p_reason,
        status='deleted', updated_at=NOW() WHERE id=p_property_id;
    INSERT INTO user_notifications (user_id, type, title, message, data, is_read, created_at)
    VALUES (v_owner_id,'property_deleted','Your property has been removed',
        CASE WHEN p_reason IS NOT NULL AND p_reason<>'' THEN 'Your property "'||v_title||'" has been removed. Reason: '||p_reason
             ELSE 'Your property "'||v_title||'" has been removed by an administrator.' END,
        jsonb_build_object('property_id',p_property_id,'reason',p_reason,'action','property_deleted'), FALSE, NOW())
    RETURNING id INTO v_notif_id;
    INSERT INTO admin_activity_log (admin_id,admin_email,admin_role,action,target_type,target_id,description,metadata,created_at)
    VALUES (p_admin_id,v_admin_email,v_admin_role,'admin_delete_property','property',p_property_id,
        'Deleted property: '||v_title, jsonb_build_object('reason',p_reason,'owner_id',v_owner_id,'notification_id',v_notif_id), NOW());
    RETURN jsonb_build_object('success',true,'message','Property deleted and owner notified','notification_sent',v_notif_id IS NOT NULL);
EXCEPTION WHEN OTHERS THEN RETURN jsonb_build_object('success',false,'error',SQLERRM,'detail',SQLSTATE);
END; $$;

CREATE FUNCTION admin_restore_property_with_notify(p_property_id UUID, p_admin_id UUID, p_note TEXT DEFAULT NULL)
RETURNS JSONB LANGUAGE plpgsql SECURITY DEFINER SET search_path = public AS $$
DECLARE v_owner_id UUID; v_title TEXT; v_admin_email TEXT; v_admin_role TEXT; v_notif_id UUID;
BEGIN
    SELECT owner_id, title INTO v_owner_id, v_title FROM properties WHERE id=p_property_id;
    IF v_owner_id IS NULL THEN RETURN jsonb_build_object('success',false,'error','Property not found'); END IF;
    SELECT COALESCE(email,'admin@system') INTO v_admin_email FROM auth.users WHERE id=p_admin_id;
    SELECT COALESCE(role,'admin') INTO v_admin_role FROM user_profiles WHERE id=p_admin_id;
    -- Clear ALL delete flags regardless of whether user or admin deleted it
    UPDATE properties SET
        deleted_at       = NULL,
        deleted_by_admin = NULL,
        deleted_by_user  = FALSE,
        deletion_reason  = NULL,
        status           = 'available',
        updated_at       = NOW()
    WHERE id=p_property_id;
    INSERT INTO user_notifications (user_id,type,title,message,data,is_read,created_at)
    VALUES (v_owner_id,'property_restored','✅ Your property has been restored',
        'Your property "'||v_title||'" has been restored by an administrator and is now visible again.'||COALESCE(' Note: '||p_note,''),
        jsonb_build_object('property_id',p_property_id,'action','property_restored'), FALSE, NOW())
    RETURNING id INTO v_notif_id;
    INSERT INTO admin_activity_log (admin_id,admin_email,admin_role,action,target_type,target_id,description,metadata,created_at)
    VALUES (p_admin_id,v_admin_email,v_admin_role,'admin_restore_property','property',p_property_id,
        'Restored property: '||v_title, jsonb_build_object('note',p_note,'owner_id',v_owner_id), NOW());
    RETURN jsonb_build_object('success',true,'message','Property restored and owner notified','notification_sent',v_notif_id IS NOT NULL);
EXCEPTION WHEN OTHERS THEN RETURN jsonb_build_object('success',false,'error',SQLERRM,'detail',SQLSTATE);
END; $$;

