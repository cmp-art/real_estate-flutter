-- ── Price Change Tracking + Notification Trigger ──────────────────────────────
CREATE TABLE IF NOT EXISTS property_price_changes (
    id          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    property_id UUID        NOT NULL REFERENCES properties(id) ON DELETE CASCADE,
    old_price   DECIMAL(15,2) NOT NULL,
    new_price   DECIMAL(15,2) NOT NULL,
    change_pct  DECIMAL(8,4)  GENERATED ALWAYS AS (
                    CASE WHEN old_price > 0
                         THEN ((new_price - old_price) / old_price) * 100
                         ELSE 0 END) STORED,
    changed_by  UUID        REFERENCES auth.users(id) ON DELETE SET NULL,
    created_at  TIMESTAMPTZ DEFAULT NOW()
);
CREATE INDEX IF NOT EXISTS idx_price_changes_property ON property_price_changes(property_id);

-- Trigger: on price drop → insert price_change row + notify favorited users
CREATE OR REPLACE FUNCTION handle_property_price_change()
RETURNS TRIGGER LANGUAGE plpgsql SECURITY DEFINER AS $$
BEGIN
    -- Only trigger on actual price decrease
    IF NEW.price >= OLD.price THEN RETURN NEW; END IF;

    -- Record the price change
    INSERT INTO property_price_changes(property_id, old_price, new_price, changed_by)
    VALUES (NEW.id, OLD.price, NEW.price, auth.uid());

    -- Notify all users who favorited this property
    INSERT INTO user_notifications(user_id, type, title, message, data)
    SELECT
        f.user_id,
        'price_drop',
        'Price Drop on ' || NEW.title,
        'Price dropped from TSh ' || OLD.price::BIGINT::TEXT ||
        ' to TSh ' || NEW.price::BIGINT::TEXT || ' — save ' ||
        ABS(((NEW.price - OLD.price) / OLD.price * 100))::INT::TEXT || '%!',
        jsonb_build_object('property_id', NEW.id, 'old_price', OLD.price, 'new_price', NEW.price)
    FROM favorites f
    WHERE f.property_id = NEW.id
      AND f.user_id != auth.uid()
    ON CONFLICT DO NOTHING;

    RETURN NEW;
END $$;

-- Attach trigger (idempotent: drop first then recreate)
DROP TRIGGER IF EXISTS trg_property_price_drop ON properties;
CREATE TRIGGER trg_property_price_drop
    AFTER UPDATE OF price ON properties
    FOR EACH ROW EXECUTE FUNCTION handle_property_price_change();

