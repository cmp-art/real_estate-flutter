CREATE OR REPLACE FUNCTION is_admin(user_id UUID)
RETURNS BOOLEAN AS $$
BEGIN
    RETURN EXISTS (
        SELECT 1 FROM user_profiles
        WHERE id = user_id AND role IN ('super_admin','admin','moderator') AND is_active = TRUE
    );
END;
$$ LANGUAGE plpgsql SECURITY DEFINER SET search_path = public;

CREATE OR REPLACE FUNCTION is_super_admin(user_id UUID)
RETURNS BOOLEAN AS $$
BEGIN
    RETURN EXISTS (SELECT 1 FROM user_profiles WHERE id = user_id AND role='super_admin' AND is_active=TRUE);
END;
$$ LANGUAGE plpgsql SECURITY DEFINER SET search_path = public;

CREATE OR REPLACE FUNCTION get_user_role(user_id UUID)
RETURNS TEXT AS $$
DECLARE user_role TEXT;
BEGIN
    SELECT role INTO user_role FROM user_profiles WHERE id = user_id;
    RETURN COALESCE(user_role, 'user');
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE OR REPLACE FUNCTION has_permission(user_id UUID, permission TEXT)
RETURNS BOOLEAN AS $$
DECLARE user_permissions JSONB; user_role TEXT;
BEGIN
    IF is_super_admin(user_id) THEN RETURN TRUE; END IF;
    SELECT permissions, role INTO user_permissions, user_role
    FROM user_profiles WHERE id = user_id AND is_active = TRUE;
    IF user_permissions IS NULL THEN RETURN FALSE; END IF;
    RETURN user_permissions ? permission;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE OR REPLACE FUNCTION log_admin_action(
    p_admin_id UUID, p_action TEXT, p_target_type TEXT DEFAULT NULL,
    p_target_id UUID DEFAULT NULL, p_description TEXT DEFAULT NULL, p_metadata JSONB DEFAULT NULL
)
RETURNS UUID AS $$
DECLARE v_admin_email TEXT; v_admin_role TEXT; v_log_id UUID;
BEGIN
    SELECT u.email, p.role INTO v_admin_email, v_admin_role
    FROM auth.users u JOIN user_profiles p ON p.id = u.id WHERE u.id = p_admin_id;
    INSERT INTO admin_activity_log (admin_id, admin_email, admin_role, action, target_type, target_id, description, metadata)
    VALUES (p_admin_id, COALESCE(v_admin_email,'admin@system'), COALESCE(v_admin_role,'admin'),
            p_action, p_target_type, p_target_id, p_description, p_metadata)
    RETURNING id INTO v_log_id;
    RETURN v_log_id;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

