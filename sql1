            WHERE id = conversation_id
              AND (auth.uid() = user1_id OR auth.uid() = user2_id)
        )
    );

-- ============================================================================
-- FIX: Two separate UPDATE policies replace the old broken single policy.
--
-- Policy 1 — "Senders can edit their own messages"
-- Covers: edit message content, soft-delete (is_deleted), hard-delete triggers.
-- Restricted to: the message sender only (auth.uid() = sender_id).
--
-- Policy 2 — "Participants can mark messages as read"
-- Covers: markMessagesAsRead() — sets is_read = TRUE on messages sent by
-- the OTHER user that the current user received.
-- Restricted to: conversation participants who are NOT the sender.
-- The WITH CHECK (is_read = TRUE) ensures recipients can ONLY flip is_read
-- and cannot modify any other column (content, sender_id, type, etc.).
-- ============================================================================

CREATE POLICY "Senders can edit their own messages"
    ON messages FOR UPDATE
    USING (auth.uid() = sender_id);

CREATE POLICY "Participants can mark messages as read"
    ON messages FOR UPDATE
    USING (
        -- Must be in the conversation
        EXISTS (
            SELECT 1 FROM conversations
            WHERE id = messages.conversation_id
              AND (auth.uid() = user1_id OR auth.uid() = user2_id)
        )
        -- But NOT the sender (recipients mark messages as read, not senders)
        AND auth.uid() != sender_id
    )
    WITH CHECK (
        -- Recipients may ONLY set is_read = TRUE — no other column changes allowed
        is_read = TRUE
    );

CREATE POLICY "Users can delete their own messages"
    ON messages FOR DELETE
    USING (auth.uid() = sender_id);

