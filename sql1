-- ============================================================================
-- PART 14: get_user_conversations() RPC
-- Replaces the N+1 Dart query loop in ChatRemoteDataSource.getConversations().
-- Was O(3n) DB queries (3 calls per conversation). Now O(1) — one server-side
-- SQL statement returns all conversations with participant info, property
-- snippet and per-conversation unread count.
--
-- Flutter usage:
--   final data = await supabase.rpc('get_user_conversations',
--       params: {'p_user_id': userId});
-- ============================================================================

-- Drop ALL overloads of get_user_conversations (handles the case where
-- previous failed runs left behind multiple versions with different signatures).
DO $$
DECLARE r RECORD;
BEGIN
    FOR r IN
        SELECT oid::regprocedure::text AS sig
        FROM   pg_proc
        WHERE  proname        = 'get_user_conversations'
          AND  pronamespace   = (SELECT oid FROM pg_namespace WHERE nspname = 'public')
    LOOP
        EXECUTE 'DROP FUNCTION IF EXISTS ' || r.sig || ' CASCADE';
    END LOOP;
END $$;

CREATE OR REPLACE FUNCTION get_user_conversations(p_user_id UUID)
RETURNS TABLE (
    id                  UUID,
    user1_id            UUID,
    user2_id            UUID,
    property_id         UUID,
    last_message        TEXT,
    last_message_time   TIMESTAMPTZ,
    updated_at          TIMESTAMPTZ,
    created_at          TIMESTAMPTZ,
    other_user_id       UUID,
    other_user_name     TEXT,
    other_user_avatar   TEXT,
    property_title      TEXT,
    property_image      TEXT,
    unread_count        BIGINT
)
LANGUAGE sql
STABLE
SECURITY DEFINER
SET search_path = public
AS $$
    SELECT
        c.id,
        c.user1_id,
        c.user2_id,
        c.property_id,
        c.last_message,
        c.last_message_time,
        c.updated_at,
        c.created_at,

        -- Other participant
        other_u.id          AS other_user_id,
        other_u.full_name   AS other_user_name,
        other_u.avatar_url  AS other_user_avatar,

        -- Property snippet (NULL for direct-message conversations)
        p.title             AS property_title,
        p.images[1]         AS property_image,   -- images is TEXT[], use [1] not ->>

        -- Unread count: messages not from caller, unread, not soft-deleted by caller
        COALESCE((
            SELECT COUNT(*)
            FROM   messages m
            LEFT JOIN user_deleted_messages udm
                   ON udm.message_id = m.id
                  AND udm.user_id    = p_user_id
            WHERE  m.conversation_id = c.id
              AND  m.sender_id      <> p_user_id
              AND  m.is_read         = FALSE
              AND  udm.message_id   IS NULL
        ), 0)               AS unread_count

    FROM  conversations c

    -- Use user_profiles (authoritative profile store) so that chat avatars
    -- and names always match what the rest of the app displays.
    LEFT JOIN  user_profiles other_u
          ON  other_u.id = CASE
                  WHEN c.user1_id = p_user_id THEN c.user2_id
                  ELSE c.user1_id
              END

    LEFT JOIN properties p ON p.id = c.property_id

    WHERE (c.user1_id = p_user_id OR c.user2_id = p_user_id)
    ORDER BY c.updated_at DESC;
$$;

GRANT EXECUTE ON FUNCTION get_user_conversations(UUID) TO authenticated;

COMMENT ON FUNCTION get_user_conversations IS
    'Returns all conversations for a user in a single query with other-user '
    'info, property snippet, and per-conversation unread count. '
    'Replaces the N+1 Dart loop that was responsible for >100 GB egress.';

