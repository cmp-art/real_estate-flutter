CREATE TABLE IF NOT EXISTS property_views (
    id          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    property_id UUID        NOT NULL REFERENCES properties(id) ON DELETE CASCADE,
    viewer_id   UUID        REFERENCES auth.users(id) ON DELETE SET NULL,
    viewer_ip   TEXT,
    platform    TEXT,
    created_at  TIMESTAMPTZ DEFAULT NOW()
);
CREATE INDEX IF NOT EXISTS idx_property_views_property_id ON property_views(property_id);
CREATE INDEX IF NOT EXISTS idx_property_views_created_at  ON property_views(created_at DESC);

-- Deduplicated view counter (1 view per user per property per hour)
CREATE OR REPLACE FUNCTION record_property_view(p_property_id UUID, p_viewer_id UUID DEFAULT NULL)
RETURNS void LANGUAGE plpgsql SECURITY DEFINER AS $$
BEGIN
    -- Skip if this user viewed in the last hour
    IF p_viewer_id IS NOT NULL AND EXISTS (
        SELECT 1 FROM property_views
        WHERE property_id = p_property_id
          AND viewer_id   = p_viewer_id
          AND created_at  > NOW() - INTERVAL '1 hour'
    ) THEN RETURN; END IF;

    INSERT INTO property_views(property_id, viewer_id)
    VALUES (p_property_id, p_viewer_id);
END $$;

-- Get view count for a property today
CREATE OR REPLACE FUNCTION get_property_view_count(p_property_id UUID, p_hours INT DEFAULT 24)
RETURNS BIGINT LANGUAGE SQL STABLE AS $$
    SELECT COUNT(*) FROM property_views
    WHERE property_id = p_property_id
      AND created_at  > NOW() - (p_hours || ' hours')::INTERVAL;
$$;

GRANT EXECUTE ON FUNCTION record_property_view(UUID, UUID) TO authenticated, anon;
GRANT EXECUTE ON FUNCTION get_property_view_count(UUID, INT) TO authenticated, anon;

