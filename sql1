DROP TRIGGER IF EXISTS cleanup_soft_deletes_on_hard_delete ON messages;
CREATE TRIGGER cleanup_soft_deletes_on_hard_delete
    BEFORE DELETE ON messages
    FOR EACH ROW
    EXECUTE FUNCTION cleanup_soft_deletes();

