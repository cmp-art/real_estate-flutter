-- ============================================================================
-- BUG FIX: Drop the broken read-receipt policies so we can replace them.
-- The old "Users can update their own messages" policy used:
--     USING (auth.uid() = sender_id)
-- This meant ONLY the sender could UPDATE a message row — so when the
-- recipient called markMessagesAsRead(), Supabase silently updated 0 rows
-- (RLS filtered them all out) and returned no error. The unread badge
-- never cleared because is_read was never actually set to TRUE in the DB.
--
-- We replace it with two separate, purpose-specific UPDATE policies:
--   1. Senders can edit their own message content (edit/delete flow)
--   2. Conversation participants can mark messages as read (read-receipt flow)
-- ============================================================================
DROP POLICY IF EXISTS "Senders can edit their own messages"             ON messages;
DROP POLICY IF EXISTS "Participants can mark messages as read"          ON messages;

DROP POLICY IF EXISTS "Users can view their own deleted messages"       ON user_deleted_messages;
DROP POLICY IF EXISTS "Users can view their deleted messages"           ON user_deleted_messages;
DROP POLICY IF EXISTS "Users can delete messages for themselves"        ON user_deleted_messages;
DROP POLICY IF EXISTS "Users can update their own deletion records"     ON user_deleted_messages;
DROP POLICY IF EXISTS "Users can remove their own deletion records"     ON user_deleted_messages;
DROP POLICY IF EXISTS "Users can manage their deleted messages"         ON user_deleted_messages;

