-- Auto-cleanup: keep only 180 days of analytics data
CREATE OR REPLACE FUNCTION cleanup_old_analytics() RETURNS void
LANGUAGE plpgsql SECURITY DEFINER AS $$
BEGIN
    DELETE FROM analytics_events WHERE created_at < NOW() - INTERVAL '180 days';
    DELETE FROM app_errors        WHERE created_at < NOW() - INTERVAL '90 days' AND resolved = TRUE;
    -- property_views: keep only 90 days (deduplicated hourly inserts grow very fast)
    DELETE FROM property_views    WHERE created_at < NOW() - INTERVAL '90 days';
END $$;

-- Schedule nightly cleanup at 2 AM UTC
DO $$
BEGIN
    PERFORM cron.unschedule('cleanup-old-analytics')
        WHERE EXISTS (SELECT 1 FROM cron.job WHERE jobname = 'cleanup-old-analytics');
EXCEPTION WHEN OTHERS THEN NULL;
END $$;

DO $$
BEGIN
    PERFORM cron.schedule('cleanup-old-analytics', '0 2 * * *',
        'SELECT cleanup_old_analytics()');
EXCEPTION WHEN OTHERS THEN
    RAISE NOTICE 'pg_cron not available — analytics cleanup cron skipped. Enable pg_cron in Supabase Dashboard.';
END $$;

