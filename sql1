-- ============================================================================
-- VERIFICATION
-- ============================================================================
DO $$
DECLARE
    v_conv              INT;
    v_msg               INT;
    v_pol               INT;
    v_cfg               INT;
    v_buckets           INT;
    v_read_policy_exists    BOOLEAN;
    v_rpc_exists            BOOLEAN;
    v_idx_lookup_exists     BOOLEAN;
BEGIN
    SELECT COUNT(*) INTO v_conv FROM conversations;
    SELECT COUNT(*) INTO v_msg  FROM messages;
    SELECT COUNT(*) INTO v_pol  FROM pg_policies
        WHERE tablename IN ('conversations','messages','user_deleted_messages','objects');
    SELECT COUNT(*) INTO v_cfg  FROM app_config;
    SELECT COUNT(*) INTO v_buckets FROM storage.buckets
        WHERE id IN ('property_images','property_videos');

    -- Verify the critical read-receipt policy was created
    SELECT EXISTS (
        SELECT 1 FROM pg_policies
        WHERE tablename  = 'messages'
          AND policyname = 'Participants can mark messages as read'
          AND schemaname = 'public'
    ) INTO v_read_policy_exists;

    -- Verify get_user_conversations() RPC
    SELECT EXISTS (
        SELECT 1 FROM pg_proc p
        JOIN pg_namespace n ON n.oid = p.pronamespace
        WHERE p.proname = 'get_user_conversations' AND n.nspname = 'public'
    ) INTO v_rpc_exists;

    -- Verify new lookup index
    SELECT EXISTS (
        SELECT 1 FROM pg_indexes WHERE indexname = 'idx_user_deleted_messages_lookup'
    ) INTO v_idx_lookup_exists;

    RAISE NOTICE '=== FILE 1: CORE DATABASE SETUP COMPLETE ===';
    RAISE NOTICE '  Conversations: %  Messages: %  RLS policies: %', v_conv, v_msg, v_pol;
    RAISE NOTICE '  app_config rows: %  (AI validation uses on-device MobileNet V3 TFLite — no API key needed)', v_cfg;
    RAISE NOTICE '  Storage buckets (property_images + property_videos): %/2', v_buckets;
    RAISE NOTICE '  Read-receipt RLS policy     : %',
        CASE WHEN v_read_policy_exists
             THEN '✅ CREATED — markMessagesAsRead() will now work correctly'
             ELSE '❌ MISSING — unread badge bug will persist!' END;
    RAISE NOTICE '  get_user_conversations RPC  : %',
        CASE WHEN v_rpc_exists THEN '✅ CREATED' ELSE '❌ MISSING — re-run' END;
    RAISE NOTICE '  idx_user_deleted_messages_lookup : %',
        CASE WHEN v_idx_lookup_exists THEN '✅' ELSE '❌' END;
    RAISE NOTICE '  IMPORTANT: set FileOptions(cacheControl:''31536000'') on ALL storage uploads in Flutter';

    IF NOT v_read_policy_exists THEN
        RAISE WARNING '❌ "Participants can mark messages as read" policy is missing! Re-run this file.';
    END IF;
    IF NOT v_rpc_exists THEN
        RAISE WARNING '❌ get_user_conversations() RPC is missing — egress optimisation not active.';
    END IF;
END $$;
