# ============================================================
# Makazi Estate — Flutter App Environment Variables
# ============================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your real values
# 3. NEVER commit .env — it is already in .gitignore
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── GOOGLE SIGN-IN ───────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials
# Use the Web Client ID (not Android or iOS)
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# ── DIRECT ADVERTISING ───────────────────────────────────────
DIRECT_ADS_ENABLED=true
MIN_CPM_RATE=1500
MIN_CPC_RATE=400
AD_FREQUENCY_FREE=5
AD_FREQUENCY_BASIC=10

# ── SELCOM PAYMENT BACKEND ───────────────────────────────────
# Your deployed backend URL (Railway / Render / VPS)
# Leave empty to run in demo mode (payments simulated)
SELCOM_BACKEND_URL=https://your-backend.up.railway.app

# ── APP CONFIGURATION ────────────────────────────────────────
APP_VERSION=1.0.0
APP_ENVIRONMENT=development
API_TIMEOUT=30000

# ── FEATURE FLAGS ────────────────────────────────────────────
ENABLE_VIDEO_TOURS=true
ENABLE_VIRTUAL_TOURS=true
ENABLE_CHAT=true
ENABLE_NOTIFICATIONS=true
