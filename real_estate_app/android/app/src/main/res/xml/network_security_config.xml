<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration
  - Blocks all plain-text (HTTP) traffic to prevent data interception.
  - Trusts the system CA store for all HTTPS connections (Supabase, Google, Stripe, etc.).
  - Cleartext is permitted only for localhost / 10.0.2.2 (Android emulator host)
    so that local dev servers can be reached without a certificate.

  IMPORTANT: Android does NOT allow <domain-config> nested inside <debug-overrides>.
  Doing so causes a fatal XmlConfigSource$ParserException at app startup, which
  kills the process before the Flutter engine loads (visible as the "Waiting for
  VM Service port to be available..." hang in Flutter tools).
  The <domain-config> must be a top-level sibling of <debug-overrides>.
-->
<network-security-config>

    <!-- Production baseline: HTTPS only, trust system CAs -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
      Allow cleartext HTTP to local addresses only (emulator host + loopback).
      Top-level <domain-config> — must NOT be inside <debug-overrides>.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

    <!--
      Debug builds only: also trust user-installed CAs (Charles, mitmproxy, etc.).
      Only <trust-anchors> is valid here — no <domain-config> allowed.
    -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

</network-security-config>
