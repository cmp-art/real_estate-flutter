<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon — required for Android 8.0+ (API 26+).
  Without this file, launcher icons appear as a plain square on modern
  devices instead of the system-defined shape (circle, squircle, etc.).

  SETUP:
    1. Replace android:drawable="@mipmap/ic_launcher" on both lines below
       with separate foreground / background layers once you have those assets:

         <foreground android:drawable="@drawable/ic_launcher_foreground"/>
         <background android:drawable="@drawable/ic_launcher_background"/>

    2. The foreground should be your logo on a transparent canvas
       (safe-zone: the centre 66 × 66 dp of a 108 × 108 dp canvas).
    3. The background can be a solid colour or branded pattern.

  For now we reference the existing icon as both layers — this is valid
  and removes the Play Store "missing adaptive icon" warning while you
  design the final assets.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@mipmap/ic_launcher" />
    <foreground android:drawable="@mipmap/ic_launcher" />
</adaptive-icon>
