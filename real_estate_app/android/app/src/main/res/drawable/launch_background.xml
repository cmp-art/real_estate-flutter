<?xml version="1.0" encoding="utf-8"?>
<!--
  Splash screen background — shown while the Flutter engine initialises.
  Brand colour: #2196F3 (Patamjengo Blue) matching ThemeConfig.lightPrimary.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Patamjengo brand blue background -->
    <item android:drawable="@color/splash_background" />

    <!-- Centred app icon -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/ic_launcher" />
    </item>
</layer-list>
