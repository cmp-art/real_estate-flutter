    signal_type     TEXT        NOT NULL,  -- e.g. 'repeated_rejection', 'gps_spoofing_suspected', 'ocr_mismatch'
    description     TEXT,
    metadata        JSONB       DEFAULT '{}'::JSONB,
    created_at      TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX idx_vfs_user_id ON verification_fraud_signals(user_id, created_at DESC);

