    DROP FUNCTION IF EXISTS create_advertiser_for_user()                               CASCADE;
    DROP FUNCTION IF EXISTS get_advertiser_by_user_id(UUID)                            CASCADE;
    DROP FUNCTION IF EXISTS get_eligible_ads(UUID,TEXT,UUID,INTEGER)                   CASCADE;
    DROP FUNCTION IF EXISTS get_eligible_ads(UUID,TEXT,UUID,INT)                       CASCADE;
    DROP FUNCTION IF EXISTS get_eligible_ads(UUID,TEXT,UUID,INT,TEXT,TEXT)             CASCADE;
