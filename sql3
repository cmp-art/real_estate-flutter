-- ============================================================================
-- PART 7: ROW LEVEL SECURITY
-- Without RLS any authenticated user can read all advertisers' campaigns,
-- budgets, targeting, and impression data. This must be enabled before release.
-- SECURITY DEFINER functions bypass RLS so serving/billing still works.
-- ============================================================================

ALTER TABLE advertisers       ENABLE ROW LEVEL SECURITY;
ALTER TABLE ad_campaigns      ENABLE ROW LEVEL SECURITY;
ALTER TABLE ad_creatives      ENABLE ROW LEVEL SECURITY;
ALTER TABLE ad_impressions    ENABLE ROW LEVEL SECURITY;
ALTER TABLE ad_clicks         ENABLE ROW LEVEL SECURITY;
ALTER TABLE advertiser_payments ENABLE ROW LEVEL SECURITY;

-- Advertisers: each user sees only their own row
DROP POLICY IF EXISTS "Advertiser sees own profile"    ON advertisers;
DROP POLICY IF EXISTS "Advertiser updates own profile" ON advertisers;
CREATE POLICY "Advertiser sees own profile"
    ON advertisers FOR SELECT TO authenticated
    USING (user_id = auth.uid() OR is_admin(auth.uid()));
CREATE POLICY "Advertiser updates own profile"
    ON advertisers FOR UPDATE TO authenticated
    USING (user_id = auth.uid() OR is_admin(auth.uid()));

-- Campaigns: advertiser sees own, admin sees all
DROP POLICY IF EXISTS "Advertiser sees own campaigns" ON ad_campaigns;
DROP POLICY IF EXISTS "Advertiser manages own campaigns" ON ad_campaigns;
CREATE POLICY "Advertiser sees own campaigns"
    ON ad_campaigns FOR SELECT TO authenticated
    USING (
        advertiser_id IN (SELECT id FROM advertisers WHERE user_id = auth.uid())
        OR is_admin(auth.uid())
    );
CREATE POLICY "Advertiser manages own campaigns"
    ON ad_campaigns FOR ALL TO authenticated
    USING (
        advertiser_id IN (SELECT id FROM advertisers WHERE user_id = auth.uid())
        OR is_admin(auth.uid())
    );

-- Creatives: same as campaigns
DROP POLICY IF EXISTS "Advertiser sees own creatives" ON ad_creatives;
DROP POLICY IF EXISTS "Advertiser manages own creatives" ON ad_creatives;
CREATE POLICY "Advertiser sees own creatives"
    ON ad_creatives FOR SELECT TO authenticated
    USING (
        campaign_id IN (
            SELECT c.id FROM ad_campaigns c
            JOIN advertisers a ON a.id = c.advertiser_id
            WHERE a.user_id = auth.uid()
        )
        OR is_admin(auth.uid())
    );
CREATE POLICY "Advertiser manages own creatives"
    ON ad_creatives FOR ALL TO authenticated
    USING (
        campaign_id IN (
            SELECT c.id FROM ad_campaigns c
            JOIN advertisers a ON a.id = c.advertiser_id
            WHERE a.user_id = auth.uid()
        )
        OR is_admin(auth.uid())
    );

-- Impressions & clicks: advertiser sees own, users cannot read directly
-- (all writes go through SECURITY DEFINER functions)
DROP POLICY IF EXISTS "Advertiser sees own impressions" ON ad_impressions;
DROP POLICY IF EXISTS "Advertiser sees own clicks"      ON ad_clicks;
DROP POLICY IF EXISTS "Service inserts impressions"     ON ad_impressions;
DROP POLICY IF EXISTS "Service inserts clicks"          ON ad_clicks;
CREATE POLICY "Advertiser sees own impressions"
    ON ad_impressions FOR SELECT TO authenticated
