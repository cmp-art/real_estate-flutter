-- ── Fraud signal trigger ──────────────────────────────────────────────────────
-- After any rejected verification, check how many times this user has been
-- rejected in the last 24 hours.  3+ rejections → log a fraud signal.
CREATE OR REPLACE FUNCTION flag_repeated_verification_failures()
RETURNS TRIGGER LANGUAGE plpgsql SECURITY DEFINER SET search_path = public AS $$
DECLARE
    v_count INT;
BEGIN
    IF NEW.status <> 'rejected' THEN RETURN NEW; END IF;

    SELECT COUNT(*) INTO v_count
    FROM   property_verifications
    WHERE  user_id    = NEW.user_id
      AND  status     = 'rejected'
      AND  created_at >= NOW() - INTERVAL '24 hours';

    IF v_count >= 3 THEN
        INSERT INTO verification_fraud_signals (
            user_id, verification_id, signal_type, description, metadata
        )
        VALUES (
            NEW.user_id,
            NEW.id,
            'repeated_rejection',
            'User has ' || v_count || ' failed verifications in the last 24 hours',
            jsonb_build_object(
                'method',          NEW.method,
                'rejection_count', v_count,
                'total_score',     NEW.total_score,
                'name_match_pct',  NEW.name_match_pct
            )
        )
        ON CONFLICT DO NOTHING;
    END IF;

    RETURN NEW;
END;
$$;

CREATE TRIGGER trg_fraud_on_rejected_verification
    AFTER INSERT ON property_verifications
    FOR EACH ROW EXECUTE FUNCTION flag_repeated_verification_failures();

-- ── log_ownership_verification() ─────────────────────────────────────────────
-- Called by the Flutter app immediately before (or after) property submission.
-- Returns the verification id so the app can attach it to the property row.
-- Signature mirrors on-device output — unused fields are passed as NULL.
CREATE OR REPLACE FUNCTION log_ownership_verification(
    p_property_id         UUID,          -- NULL if property not yet created
    p_user_id             UUID,
    p_method              TEXT,          -- 'near_owner' | 'far_owner'
    p_status              TEXT,          -- 'verified' | 'rejected'
    -- near owner
    p_gps_score           INT     DEFAULT NULL,
    p_photo_score         INT     DEFAULT NULL,
    p_total_score         INT     DEFAULT NULL,
    p_distance_meters     NUMERIC DEFAULT NULL,
    -- far owner
    p_id_document_type    TEXT    DEFAULT NULL,
    p_id_name_extracted   TEXT    DEFAULT NULL,
    p_hati_name_extracted TEXT    DEFAULT NULL,
    p_name_match_pct      NUMERIC DEFAULT NULL,
    -- diagnostics
    p_rejection_reason    TEXT    DEFAULT NULL,
    p_device_locale       TEXT    DEFAULT NULL,
    p_app_version         TEXT    DEFAULT NULL
)
RETURNS UUID
LANGUAGE plpgsql SECURITY DEFINER SET search_path = public
AS $$
DECLARE
    v_id UUID;
BEGIN
    INSERT INTO property_verifications (
        property_id, user_id, method, status,
        distance_meters, gps_score, photo_score, total_score,
        id_document_type, id_name_extracted, hati_name_extracted, name_match_pct,
        rejection_reason, device_locale, app_version
    )
    VALUES (
        p_property_id, p_user_id, p_method, p_status,
        p_distance_meters, p_gps_score, p_photo_score, p_total_score,
        p_id_document_type, p_id_name_extracted, p_hati_name_extracted, p_name_match_pct,
        p_rejection_reason, p_device_locale, p_app_version
    )
    RETURNING id INTO v_id;

    -- If verified and property exists → stamp the properties row
    IF p_status = 'verified' AND p_property_id IS NOT NULL THEN
        UPDATE properties
        SET    is_owner_verified   = TRUE,
               verification_method = p_method,
               verified_at         = NOW()
        WHERE  id = p_property_id;
    END IF;

    RETURN v_id;
END;
$$;

GRANT EXECUTE ON FUNCTION log_ownership_verification(
    UUID,UUID,TEXT,TEXT,INT,INT,INT,NUMERIC,TEXT,TEXT,TEXT,NUMERIC,TEXT,TEXT,TEXT
) TO authenticated;

-- ── RLS ───────────────────────────────────────────────────────────────────────
ALTER TABLE property_verifications     ENABLE ROW LEVEL SECURITY;
ALTER TABLE verification_fraud_signals ENABLE ROW LEVEL SECURITY;

-- Users can insert their own verification records; only admins can read all
DROP POLICY IF EXISTS "Users insert own verifications"   ON property_verifications;
DROP POLICY IF EXISTS "Users see own verifications"      ON property_verifications;
DROP POLICY IF EXISTS "Admins manage all verifications"  ON property_verifications;
CREATE POLICY "Users insert own verifications"
    ON property_verifications FOR INSERT TO authenticated
    WITH CHECK (user_id = auth.uid());
CREATE POLICY "Users see own verifications"
    ON property_verifications FOR SELECT TO authenticated
    USING (user_id = auth.uid() OR is_admin(auth.uid()));
CREATE POLICY "Admins manage all verifications"
    ON property_verifications FOR ALL TO authenticated
    USING (is_admin(auth.uid()));

-- Fraud signals: insert from app or trigger; admins read all; users see none
DROP POLICY IF EXISTS "Anyone inserts fraud signals"    ON verification_fraud_signals;
DROP POLICY IF EXISTS "Admins manage fraud signals"     ON verification_fraud_signals;
CREATE POLICY "Anyone inserts fraud signals"
    ON verification_fraud_signals FOR INSERT
    WITH CHECK (TRUE);
CREATE POLICY "Admins manage fraud signals"
    ON verification_fraud_signals FOR ALL TO authenticated
    USING (is_admin(auth.uid()));

GRANT SELECT, INSERT ON property_verifications     TO authenticated;
GRANT INSERT         ON verification_fraud_signals TO authenticated;
GRANT ALL            ON property_verifications     TO service_role;
GRANT ALL            ON verification_fraud_signals TO service_role;

