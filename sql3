-- ============================================================================
-- PART 8: CRON JOBS
-- Two critical scheduled tasks:
--   1. Daily reset at midnight UTC (= 3 AM Tanzania): restore out_of_budget
--      campaigns back to running so they serve ads the next day.
--   2. Hourly completion check: mark campaigns whose end_date has passed
--      as completed so they stop trying to serve ads.
--
-- PREREQUISITE: Enable pg_cron in Supabase Dashboard → Database → Extensions
-- These DO blocks are safe to run whether or not pg_cron is installed.
-- If pg_cron is not yet enabled they log a NOTICE and skip silently.
-- ============================================================================

-- Step 1: Remove old job entries (idempotent)
DO $$
BEGIN
    IF EXISTS (SELECT 1 FROM pg_extension WHERE extname = 'pg_cron') THEN
        PERFORM cron.unschedule(jobid)
        FROM cron.job
        WHERE jobname IN ('reset-daily-budgets', 'complete-expired-campaigns');
    END IF;
EXCEPTION WHEN OTHERS THEN
    NULL; -- pg_cron not installed yet — skip silently
END $$;

-- Step 2: Register jobs
-- NOTE: the inner SQL strings use a custom dollar-tag delimiter (dollar-job-dollar)
--       rather than the standard double-dollar, so they do not collide with the
--       outer DO block delimiter.
DO $$
BEGIN
    -- Job 1: every midnight UTC (= 3 AM Tanzania) — restore daily-budget-exhausted campaigns
    PERFORM cron.schedule(
        'reset-daily-budgets',
        '0 0 * * *',
        $job$
        UPDATE ad_campaigns
        SET    status     = 'running',
               updated_at = NOW()
        WHERE  status      = 'out_of_budget'
          AND  deleted_at  IS NULL
          AND  spent_amount < total_budget
          AND  end_date    >= NOW();
        $job$
    );

    -- Job 2: every hour — mark expired campaigns as completed
    PERFORM cron.schedule(
        'complete-expired-campaigns',
        '0 * * * *',
        $job$
        UPDATE ad_campaigns
        SET    status     = 'completed',
               updated_at = NOW()
        WHERE  status    IN ('running', 'paused', 'out_of_budget')
          AND  end_date  < NOW()
          AND  deleted_at IS NULL;
        $job$
    );

    RAISE NOTICE '✅ pg_cron jobs registered: reset-daily-budgets (midnight), complete-expired-campaigns (hourly)';
EXCEPTION WHEN OTHERS THEN
    RAISE NOTICE 'pg_cron not available — cron jobs skipped. Enable pg_cron in Supabase Dashboard → Database → Extensions, then re-run this file.';
END $$;

