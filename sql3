CREATE TABLE advertisers (
    id                      UUID    PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id                 UUID    UNIQUE REFERENCES auth.users(id) ON DELETE CASCADE,
    company_name            TEXT    NOT NULL,
    contact_name            TEXT    NOT NULL,
    email                   TEXT    UNIQUE NOT NULL,
    phone                   TEXT    NOT NULL,
    company_type            TEXT    NOT NULL DEFAULT 'real_estate_agency'
                            CHECK (company_type IN (
                                'real_estate_agency','property_developer','mortgage_lender',
                                'insurance_company','moving_company','home_services',
                                'furniture_store','construction_company')),
    company_website         TEXT,
    company_description     TEXT,
    is_verified             BOOLEAN DEFAULT FALSE,
    verification_document_url TEXT,
    verified_at             TIMESTAMPTZ,
    verified_by             UUID    REFERENCES auth.users(id),
    status                  TEXT    DEFAULT 'active'
                            CHECK (status IN ('pending','active','suspended','banned')),
    account_balance         DECIMAL(15,2) DEFAULT 0.00 CHECK (account_balance >= 0),
    total_spent             DECIMAL(15,2) DEFAULT 0.00 CHECK (total_spent >= 0),
    currency                TEXT    DEFAULT 'TZS',
    auto_recharge           BOOLEAN DEFAULT FALSE,
    auto_recharge_amount    DECIMAL(10,2) DEFAULT 50000.00,
    auto_recharge_threshold DECIMAL(10,2) DEFAULT 10000.00,
    last_login_at           TIMESTAMPTZ,
    created_at              TIMESTAMPTZ DEFAULT NOW(),
    updated_at              TIMESTAMPTZ DEFAULT NOW(),
    CONSTRAINT valid_email CHECK (email ~* '^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$')
);

CREATE INDEX idx_advertisers_user_id ON advertisers(user_id);
CREATE INDEX idx_advertisers_email   ON advertisers(email);
CREATE INDEX idx_advertisers_status  ON advertisers(status);

CREATE TABLE ad_campaigns (
    id                   UUID    PRIMARY KEY DEFAULT gen_random_uuid(),
    advertiser_id        UUID    NOT NULL REFERENCES advertisers(id) ON DELETE CASCADE,
    campaign_name        TEXT    NOT NULL,
    campaign_objective   TEXT    NOT NULL
                         CHECK (campaign_objective IN (
                             'brand_awareness','property_inquiries','website_visits',
                             'phone_calls','app_installs')),
    target_property_types JSONB  DEFAULT '[]'::JSONB,
    target_locations     JSONB   DEFAULT '[]'::JSONB,
    target_price_range   JSONB,
    target_user_interests JSONB  DEFAULT '[]'::JSONB,
    daily_budget         DECIMAL(10,2) NOT NULL CHECK (daily_budget > 0),
    total_budget         DECIMAL(10,2) NOT NULL DEFAULT 999999.00 CHECK (total_budget > 0),
    bid_amount           DECIMAL(10,2) NOT NULL CHECK (bid_amount > 0),
    bidding_strategy     TEXT    DEFAULT 'cpc' CHECK (bidding_strategy IN ('cpc','cpm')),
    start_date           TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    end_date             TIMESTAMPTZ NOT NULL DEFAULT NOW() + INTERVAL '365 days',
    schedule_hours       JSONB,
    status               TEXT    DEFAULT 'pending_review'
                         CHECK (status IN (
                             'draft','pending_review','approved','running','paused',
                             'completed','rejected','out_of_budget','cancelled')),
    spent_amount         DECIMAL(15,2) DEFAULT 0.00 CHECK (spent_amount >= 0),
    impressions_count    INTEGER DEFAULT 0 CHECK (impressions_count >= 0),
    clicks_count         INTEGER DEFAULT 0 CHECK (clicks_count >= 0),
    conversions_count    INTEGER DEFAULT 0 CHECK (conversions_count >= 0),
    ctr                  DECIMAL(5,2) DEFAULT 0.00,
    cpc_actual           DECIMAL(10,2) DEFAULT 0.00,
    conversion_rate      DECIMAL(5,2) DEFAULT 0.00,
    reviewed_by          UUID    REFERENCES auth.users(id),
    reviewed_at          TIMESTAMPTZ,
    rejection_reason     TEXT,
    -- Soft-delete columns
    deleted_at           TIMESTAMPTZ,
    deleted_by_user      BOOLEAN DEFAULT FALSE,
    deletion_reason      TEXT,
    created_at           TIMESTAMPTZ DEFAULT NOW(),
    updated_at           TIMESTAMPTZ DEFAULT NOW(),
    CONSTRAINT valid_dates          CHECK (end_date > start_date),
    CONSTRAINT spent_within_budget  CHECK (spent_amount <= total_budget)
);

CREATE INDEX idx_campaigns_advertiser ON ad_campaigns(advertiser_id);
CREATE INDEX idx_campaigns_status     ON ad_campaigns(status);
CREATE INDEX idx_campaigns_dates      ON ad_campaigns(start_date, end_date);
CREATE INDEX idx_ad_campaigns_deleted_at ON ad_campaigns(deleted_at) WHERE deleted_at IS NOT NULL;

CREATE TABLE ad_creatives (
    id              UUID    PRIMARY KEY DEFAULT gen_random_uuid(),
    campaign_id     UUID    NOT NULL REFERENCES ad_campaigns(id) ON DELETE CASCADE,
    ad_format       TEXT    NOT NULL
                    CHECK (ad_format IN (
                        'banner_300x250','banner_320x50','banner_728x90',
                        'native_small','native_medium','native_large','video_ad')),
    headline        TEXT    NOT NULL CHECK (LENGTH(headline) <= 30),
    description     TEXT    CHECK (description IS NULL OR LENGTH(description) <= 90),
    call_to_action  TEXT    NOT NULL
                    CHECK (call_to_action IN (
                        'Learn More','View Property','Contact Us','Get Quote',
                        'Call Now','Visit Website','Apply Now','Schedule Tour','Watch Video')),
    image_url       TEXT    NOT NULL CHECK (image_url ~* '^https?://'),
    logo_url        TEXT    CHECK (logo_url IS NULL OR logo_url ~* '^https?://'),
    landing_url     TEXT    NOT NULL CHECK (landing_url ~* '^https?://'),
    tracking_parameters JSONB,
    media_type      TEXT    DEFAULT 'image' CHECK (media_type IN ('image','video')),
    video_url       TEXT    CHECK (video_url IS NULL OR video_url ~* '^https?://'),
    destination_type    TEXT   DEFAULT 'whatsapp'
                        CHECK (destination_type IN ('phone','whatsapp','property','profile','website')),
    linked_property_id  UUID   REFERENCES properties(id) ON DELETE SET NULL,
    status          TEXT    DEFAULT 'paused'
                    CHECK (status IN ('active','paused','rejected','archived')),
    is_approved     BOOLEAN DEFAULT FALSE,
    impressions     INTEGER DEFAULT 0 CHECK (impressions >= 0),
    clicks          INTEGER DEFAULT 0 CHECK (clicks >= 0),
    rejection_reason TEXT,
    reviewed_by     UUID    REFERENCES auth.users(id),
    reviewed_at     TIMESTAMPTZ,
    -- AI validation columns (populated by AiValidationService before human review)
    ai_approved     BOOLEAN     DEFAULT FALSE,
    ai_confidence   INTEGER     CHECK (ai_confidence IS NULL OR ai_confidence BETWEEN 0 AND 100),
    ai_category     TEXT,
    ai_reviewed_at  TIMESTAMPTZ,
    -- Soft-delete columns
    deleted_at      TIMESTAMPTZ,
    deleted_by_user BOOLEAN DEFAULT FALSE,
    deletion_reason TEXT,
    restored_at     TIMESTAMPTZ,
    created_at      TIMESTAMPTZ DEFAULT NOW(),
    updated_at      TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX idx_creatives_campaign ON ad_creatives(campaign_id);
CREATE INDEX idx_creatives_status   ON ad_creatives(status, is_approved);
CREATE INDEX idx_ad_creatives_deleted_at ON ad_creatives(deleted_at) WHERE deleted_at IS NOT NULL;

COMMENT ON COLUMN ad_creatives.media_type       IS 'Type of media: image or video';
COMMENT ON COLUMN ad_creatives.video_url        IS 'URL to video file (for video ads)';
COMMENT ON COLUMN ad_creatives.destination_type   IS 'Where tapping the ad sends the user: phone | whatsapp | property | profile | website';
COMMENT ON COLUMN ad_creatives.linked_property_id IS 'For destination_type=property: the property to open in-app when the ad is tapped';

