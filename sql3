-- ── get_validation_stats() ────────────────────────────────────────────────────
-- Returns a JSON summary used by AdminManualReviewScreen's Stats panel.
DROP FUNCTION IF EXISTS get_validation_stats();
CREATE OR REPLACE FUNCTION get_validation_stats()
RETURNS JSONB
LANGUAGE plpgsql SECURITY DEFINER SET search_path = public
AS $$
DECLARE v_result JSONB;
BEGIN
    SELECT jsonb_build_object(
        'total_validated',     (SELECT COUNT(*) FROM ai_validation_logs),
        'ai_approved',         (SELECT COUNT(*) FROM ai_validation_logs WHERE validation_method='ai'    AND status='approved'),
        'ai_rejected',         (SELECT COUNT(*) FROM ai_validation_logs WHERE validation_method='ai'    AND status='rejected'),
        'rules_approved',      (SELECT COUNT(*) FROM ai_validation_logs WHERE validation_method='rules' AND status='approved'),
        'rules_rejected',      (SELECT COUNT(*) FROM ai_validation_logs WHERE validation_method='rules' AND status='rejected'),
        'pending_manual',      (SELECT COUNT(*) FROM manual_review_queue  WHERE status='pending'),
        'manual_approved',     (SELECT COUNT(*) FROM manual_review_queue  WHERE status='approved'),
        'manual_rejected',     (SELECT COUNT(*) FROM manual_review_queue  WHERE status='rejected'),
        'ai_usage_pct',        ROUND(
                                   (SELECT COUNT(*) FROM ai_validation_logs WHERE validation_method='ai')::NUMERIC
                                   / NULLIF((SELECT COUNT(*) FROM ai_validation_logs),0) * 100, 1),
        'rules_usage_pct',     ROUND(
                                   (SELECT COUNT(*) FROM ai_validation_logs WHERE validation_method='rules')::NUMERIC
                                   / NULLIF((SELECT COUNT(*) FROM ai_validation_logs),0) * 100, 1),
        'manual_usage_pct',    ROUND(
                                   (SELECT COUNT(*) FROM ai_validation_logs WHERE validation_method IN ('manual','failed'))::NUMERIC
                                   / NULLIF((SELECT COUNT(*) FROM ai_validation_logs),0) * 100, 1)
    ) INTO v_result;
    RETURN v_result;
END;
$$;

