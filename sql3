        OR is_admin(auth.uid())
    );
CREATE POLICY "Advertiser sees own clicks"
    ON ad_clicks FOR SELECT TO authenticated
    USING (
        advertiser_id IN (SELECT id FROM advertisers WHERE user_id = auth.uid())
        OR is_admin(auth.uid())
    );
-- Inserts only via SECURITY DEFINER functions (bypass RLS) — no direct insert policy needed

