CREATE OR REPLACE FUNCTION create_advertiser_for_user()
RETURNS TRIGGER AS $$
DECLARE v_full_name TEXT; v_phone TEXT;
BEGIN
    SELECT full_name, phone INTO v_full_name, v_phone FROM users WHERE id = NEW.id;
    IF NOT EXISTS (SELECT 1 FROM advertisers WHERE user_id = NEW.id) THEN
        INSERT INTO advertisers (user_id, company_name, contact_name, email, phone, company_type, status)
        VALUES (NEW.id, COALESCE(v_full_name,'My Company'), COALESCE(v_full_name,'Contact Person'),
                NEW.email, COALESCE(v_phone,'N/A'), 'real_estate_agency', 'active');
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- ============================================================================
-- SERVE ELIGIBLE ADS  — get_eligible_ads
-- ============================================================================
-- Only called from PropertyListScreen.
-- Parameters:
--   p_user_id             — authenticated user (for frequency cap)
--   p_screen_name         — always 'property_list' (stored in impressions for analytics)
--   p_property_id         — optional, stored in impressions for analytics
--   p_limit               — max ads to return (default 5)
--   p_user_region         — user's Tanzania region/city (NULL = no location filter applied)
--   p_user_property_type  — property type user is viewing (NULL = no type filter applied)
--
-- Rules enforced server-side:
--   1. Location targeting  — if campaign has regions set, user must be in one of them
--                            empty target_locations = "whole Tanzania" (show everywhere)
--   2. Property type       — if campaign targets types, current property type must match
--   3. Total budget gate   — spent_amount < total_budget
--   4. Daily budget gate   — today's impression cost < daily_budget
--   5. Frequency cap       — same creative not shown to same user within 4 hours
--   NOTE: account_balance is NOT checked here — the budget gate is sufficient.
--         Balance is deducted after serving (on impression/click). New advertisers
--         start with 0 balance and must top up, but the campaign budget is the gate.
-- ============================================================================
CREATE OR REPLACE FUNCTION get_eligible_ads(
    p_user_id             UUID,
    p_screen_name         TEXT    DEFAULT 'property_list',
    p_property_id         UUID    DEFAULT NULL,
    p_limit               INT     DEFAULT 5,
    p_user_region         TEXT    DEFAULT NULL,
    p_user_property_type  TEXT    DEFAULT NULL
)
RETURNS SETOF JSONB
LANGUAGE plpgsql
SECURITY DEFINER
SET search_path = public
AS $$
BEGIN
    RETURN QUERY
    SELECT jsonb_build_object(
        'campaign_id',       c.id,
        'creative_id',       cr.id,
        'advertiser_id',     c.advertiser_id,
        'headline',          cr.headline,
        'description',       cr.description,
        'call_to_action',    cr.call_to_action,
        'image_url',         cr.image_url,
        'logo_url',          cr.logo_url,
        'landing_url',       cr.landing_url,
        'bid_amount',        c.bid_amount,
        'bidding_strategy',  c.bidding_strategy,
        'media_type',        COALESCE(cr.media_type, 'image'),
        'video_url',         cr.video_url,
        'destination_type',   COALESCE(cr.destination_type, 'website'),
        'advertiser_user_id',  a.user_id,
        'linked_property_id', cr.linked_property_id
    )
    FROM  ad_campaigns c
    JOIN  ad_creatives  cr ON cr.campaign_id = c.id
    JOIN  advertisers   a  ON a.id = c.advertiser_id
    WHERE
        -- ── Core eligibility (same as old working version) ────────────────
        c.status         = 'running'
        AND c.deleted_at    IS NULL
        AND cr.deleted_at   IS NULL
        AND cr.is_approved  = TRUE
        AND cr.status       = 'active'
        AND c.start_date   <= NOW()
        AND c.end_date     >= NOW()

        -- ── Total budget not exhausted ─────────────────────────────────────
        AND c.spent_amount < c.total_budget

        -- ── Daily budget not exhausted ─────────────────────────────────────
        -- Uses impressions cost sum for today. If all costs are 0 (free tier testing)
        -- then 0 < daily_budget which is always TRUE — ads still serve correctly.
        AND (
            SELECT COALESCE(SUM(i.cost), 0)
            FROM   ad_impressions i
            WHERE  i.campaign_id = c.id
              AND  i.created_at >= CURRENT_DATE::TIMESTAMPTZ
        ) < c.daily_budget

        -- ── Location targeting ─────────────────────────────────────────────
        -- Empty array or NULL = target whole Tanzania (no restriction).
        -- If regions are set, user must be in one of them.
        -- If user region is unknown (NULL), show the ad (gives benefit of doubt).
        AND (
            c.target_locations = '[]'::JSONB
            OR  c.target_locations IS NULL
            OR  p_user_region IS NULL
            OR  c.target_locations @> to_jsonb(p_user_region::TEXT)
        )

        -- ── Property type targeting ────────────────────────────────────────
        -- Empty array or NULL = target all property types.
        -- If types are set, current property type must match.
        -- If unknown (NULL), show the ad.
        AND (
            c.target_property_types = '[]'::JSONB
            OR  c.target_property_types IS NULL
            OR  p_user_property_type IS NULL
            OR  c.target_property_types @> to_jsonb(p_user_property_type::TEXT)
        )

        -- ── Frequency cap: same creative not shown to same user more than once today ─
        -- Uses calendar day (midnight reset) not a rolling 24h window.
        -- This means a user who opens the app at 11pm and again after midnight
        -- gets a fresh set of ads — better UX than a rolling window.
        -- The Flutter side additionally guards against re-recording within
        -- a single session scroll (_sessionImpressionRecorded set).
        AND NOT EXISTS (
            SELECT 1
            FROM   ad_impressions fi
            WHERE  fi.creative_id = cr.id
              AND  fi.user_id     = p_user_id
              AND  fi.created_at >= CURRENT_DATE::TIMESTAMPTZ
        )

    -- ── Weighted-random auction ────────────────────────────────────────────────
    -- RANDOM() * bid_amount gives each ad a score proportional to its bid.
    -- A TSh 2,000 campaign is ~4× more likely to win than a TSh 500 campaign,
    -- but lower bidders still get impressions — their budget is not wasted.
    --
    -- Pure ORDER BY bid_amount DESC (strict auction) meant the highest bidder
    -- won every single slot. An advertiser with TSh 600 bid would never appear
    -- while a TSh 2,000 bidder had budget remaining. This is unfair and means
    -- small advertisers never get any value from their spend.
    --
    -- With RANDOM() * bid_amount:
    --   TSh 2,000 bid → avg score ≈ 1,000   (wins ~57% of slots vs TSh 1,500)
    --   TSh 1,500 bid → avg score ≈ 750    (wins ~43% of slots vs TSh 2,000)
    --   TSh 500  bid → avg score ≈ 250    (still wins when random is favorable)
    -- Higher budgets still dominate, but every eligible advertiser gets exposure.
    ORDER BY RANDOM() * c.bid_amount DESC
    LIMIT p_limit;
END;
$$;

GRANT EXECUTE ON FUNCTION get_eligible_ads(UUID,TEXT,UUID,INT,TEXT,TEXT) TO authenticated, anon;


-- ============================================================================
-- RECORD IMPRESSION
-- Fixes applied:
--   1. CPM billing — deducts from account_balance when bidding_strategy='cpm'
--   2. Marks campaign out_of_budget when daily OR total budget exhausted
-- ============================================================================
DROP FUNCTION IF EXISTS record_ad_impression(UUID,UUID,UUID,UUID,TEXT,UUID,DECIMAL);
CREATE OR REPLACE FUNCTION record_ad_impression(
    p_campaign_id   UUID,
    p_creative_id   UUID,
    p_advertiser_id UUID,
    p_user_id       UUID,
    p_screen_name   TEXT,
    p_property_id   UUID    DEFAULT NULL,
    p_cost          DECIMAL DEFAULT 0.00
)
RETURNS UUID AS $$
DECLARE
    v_impression_id    UUID;
    v_bidding_strategy TEXT;
    v_daily_spent      DECIMAL;
    v_daily_budget     DECIMAL;
BEGIN
    INSERT INTO ad_impressions (campaign_id, creative_id, advertiser_id, user_id, screen_name, property_id, cost)
    VALUES (p_campaign_id, p_creative_id, p_advertiser_id, p_user_id, p_screen_name, p_property_id, p_cost)
    RETURNING id INTO v_impression_id;

    -- Increment campaign counters and total spent
    UPDATE ad_campaigns
    SET    impressions_count = impressions_count + 1,
           spent_amount      = spent_amount + p_cost,
           updated_at        = NOW()
    WHERE  id = p_campaign_id;

    -- Increment creative impression counter
    UPDATE ad_creatives
    SET    impressions = impressions + 1,
           updated_at  = NOW()
    WHERE  id = p_creative_id;

    -- CPM billing: deduct from account_balance (Fix #1)
    SELECT bidding_strategy INTO v_bidding_strategy
    FROM   ad_campaigns WHERE id = p_campaign_id;

    IF v_bidding_strategy = 'cpm' AND p_cost > 0 THEN
        UPDATE advertisers
        SET    account_balance = GREATEST(account_balance - p_cost, 0),
               total_spent     = total_spent + p_cost,
               updated_at      = NOW()
        WHERE  id = p_advertiser_id;
    END IF;

    -- Check daily budget exhaustion (Fix #2)
    SELECT COALESCE(SUM(cost), 0), c.daily_budget
    INTO   v_daily_spent, v_daily_budget
    FROM   ad_impressions i
    JOIN   ad_campaigns   c ON c.id = i.campaign_id
    WHERE  i.campaign_id = p_campaign_id
      AND  i.created_at >= CURRENT_DATE
    GROUP  BY c.daily_budget;

    -- Mark out_of_budget if total OR daily budget is exhausted
    UPDATE ad_campaigns
    SET    status     = 'out_of_budget',
           updated_at = NOW()
    WHERE  id = p_campaign_id
      AND  (spent_amount >= total_budget OR COALESCE(v_daily_spent, 0) >= COALESCE(v_daily_budget, 999999));

    RETURN v_impression_id;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

GRANT EXECUTE ON FUNCTION record_ad_impression(UUID,UUID,UUID,UUID,TEXT,UUID,DECIMAL) TO authenticated, anon;

-- ============================================================================
-- RECORD CLICK
-- Fixes applied:
--   1. Server-side fraud detection — >3 clicks/day by same user on same creative
--      marks the click as fraudulent and does NOT deduct advertiser balance
-- ============================================================================
DROP FUNCTION IF EXISTS record_ad_click(UUID,UUID,UUID,UUID,UUID,DECIMAL);
CREATE OR REPLACE FUNCTION record_ad_click(
    p_impression_id UUID,
    p_campaign_id   UUID,
    p_creative_id   UUID,
    p_advertiser_id UUID,
    p_user_id       UUID,
    p_cost          DECIMAL
)
RETURNS UUID AS $$
DECLARE
    v_click_id      UUID;
    v_click_count   INT;
    v_is_fraud      BOOLEAN := FALSE;
    v_fraud_reason  TEXT;
BEGIN
    -- Server-side fraud check: >3 clicks today on same creative by same user
    SELECT COUNT(*) INTO v_click_count
    FROM   ad_clicks
    WHERE  user_id     = p_user_id
      AND  creative_id = p_creative_id
      AND  clicked_at >= CURRENT_DATE;

    IF v_click_count >= 3 THEN
        v_is_fraud     := TRUE;
        v_fraud_reason := 'Exceeded 3 clicks/day threshold (count: ' || (v_click_count + 1) || ')';
    END IF;

    INSERT INTO ad_clicks (
        impression_id, campaign_id, creative_id, advertiser_id, user_id,
        cost, is_suspicious, fraud_reason
    )
    VALUES (
        p_impression_id, p_campaign_id, p_creative_id, p_advertiser_id, p_user_id,
        CASE WHEN v_is_fraud THEN 0 ELSE p_cost END,  -- zero cost for fraud clicks
        v_is_fraud, v_fraud_reason
    )
    RETURNING id INTO v_click_id;

    -- Only update stats and deduct balance for legitimate clicks
    IF NOT v_is_fraud THEN
        UPDATE ad_campaigns SET
            clicks_count = clicks_count + 1,
            spent_amount = spent_amount + p_cost,
            ctr          = CASE WHEN impressions_count > 0
                               THEN ((clicks_count + 1.0) / impressions_count) * 100
                               ELSE 0 END,
            cpc_actual   = CASE WHEN (clicks_count + 1) > 0
                               THEN (spent_amount + p_cost) / (clicks_count + 1)
                               ELSE 0 END,
            updated_at   = NOW()
        WHERE id = p_campaign_id;

        UPDATE ad_creatives
        SET    clicks     = clicks + 1,
               updated_at = NOW()
        WHERE  id = p_creative_id;

        -- Deduct from advertiser balance (CPC) — CPM already deducted on impression
        UPDATE advertisers
        SET    account_balance = GREATEST(account_balance - p_cost, 0),
               total_spent     = total_spent + p_cost,
               updated_at      = NOW()
        WHERE  id = p_advertiser_id;

        -- Mark campaign out_of_budget if total budget exhausted
        UPDATE ad_campaigns
        SET    status     = 'out_of_budget',
               updated_at = NOW()
        WHERE  id = p_campaign_id
          AND  spent_amount >= total_budget;
    END IF;

    RETURN v_click_id;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

GRANT EXECUTE ON FUNCTION record_ad_click(UUID,UUID,UUID,UUID,UUID,DECIMAL) TO authenticated, anon;

CREATE OR REPLACE FUNCTION process_advertiser_payment(
    p_advertiser_id      UUID,
    p_amount             DECIMAL,
    p_transaction_id     TEXT,
    p_payment_method     TEXT,
    p_provider_reference TEXT DEFAULT NULL
)
RETURNS UUID AS $$
DECLARE v_payment_id UUID;
BEGIN
    -- Idempotency guard: don't credit the same transaction twice.
    -- The UNIQUE constraint on advertiser_payments.transaction_id would also
    -- catch this, but an explicit check gives a clean no-op return instead of
    -- raising an exception.
    SELECT id INTO v_payment_id
    FROM   advertiser_payments
    WHERE  transaction_id = p_transaction_id AND status = 'completed';

    IF FOUND THEN
        RETURN v_payment_id; -- already processed — return existing id
    END IF;

    INSERT INTO advertiser_payments (
        advertiser_id, amount, currency, transaction_id, payment_method,
        provider_reference, status, payment_date, completed_at
    )
    VALUES (
        p_advertiser_id, p_amount, 'TZS', p_transaction_id, p_payment_method,
        p_provider_reference, 'completed', NOW(), NOW()
    )
    ON CONFLICT (transaction_id) DO NOTHING
    RETURNING id INTO v_payment_id;

    -- Credit balance only when a new payment row was inserted
    IF v_payment_id IS NOT NULL THEN
        UPDATE advertisers
        SET    account_balance = account_balance + p_amount,
               total_spent     = total_spent,          -- balance top-up, not a spend
               updated_at      = NOW()
        WHERE  id = p_advertiser_id;
    END IF;

    RETURN v_payment_id;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Advertiser self-service soft-delete for campaigns
CREATE OR REPLACE FUNCTION soft_delete_campaign(
    p_campaign_id UUID, p_user_id UUID, p_reason TEXT DEFAULT NULL
)
RETURNS JSONB LANGUAGE plpgsql SECURITY DEFINER SET search_path = public AS $$
DECLARE
    v_campaign    ad_campaigns%ROWTYPE;
    v_advertiser  advertisers%ROWTYPE;
    v_user_email  TEXT;
    v_user_role   TEXT;
BEGIN
    SELECT * INTO v_campaign   FROM ad_campaigns WHERE id = p_campaign_id;
    IF NOT FOUND THEN RETURN jsonb_build_object('success',false,'error','Campaign not found'); END IF;
    SELECT * INTO v_advertiser FROM advertisers WHERE id = v_campaign.advertiser_id AND user_id = p_user_id;
    IF NOT FOUND THEN RETURN jsonb_build_object('success',false,'error','Not authorized'); END IF;
    IF v_campaign.deleted_at IS NOT NULL THEN RETURN jsonb_build_object('success',false,'error','Campaign is already deleted'); END IF;

    UPDATE ad_campaigns SET status='cancelled', deleted_at=NOW(),
        deleted_by_user=TRUE, deletion_reason=p_reason, updated_at=NOW()
    WHERE id = p_campaign_id;

    UPDATE ad_creatives SET status='archived', deleted_at=NOW(), deleted_by_user=TRUE,
        deletion_reason='Parent campaign cancelled by advertiser', updated_at=NOW()
    WHERE campaign_id = p_campaign_id AND deleted_at IS NULL;

    BEGIN
        SELECT email INTO v_user_email FROM auth.users WHERE id = p_user_id;
        SELECT COALESCE(role,'advertiser') INTO v_user_role FROM user_profiles WHERE id = p_user_id;
        INSERT INTO admin_activity_log (admin_id, admin_email, admin_role, action, target_type, target_id, description, metadata, created_at)
        VALUES (p_user_id, COALESCE(v_user_email,'unknown'), COALESCE(v_user_role,'advertiser'),
            'advertiser_delete_campaign','ad_campaign',p_campaign_id,
            COALESCE(p_reason,'Campaign cancelled by advertiser'),
            jsonb_build_object('campaign_name',v_campaign.campaign_name,'spent_amount',v_campaign.spent_amount), NOW());
    EXCEPTION WHEN OTHERS THEN NULL;
    END;

    RETURN jsonb_build_object('success',true,'message','Campaign archived. All billing records are preserved.');
EXCEPTION WHEN OTHERS THEN RETURN jsonb_build_object('success',false,'error',SQLERRM);
END;
$$;

-- Advertiser self-service soft-delete for creatives
CREATE OR REPLACE FUNCTION soft_delete_creative(
    p_creative_id UUID, p_user_id UUID, p_reason TEXT DEFAULT NULL
)
RETURNS JSONB LANGUAGE plpgsql SECURITY DEFINER SET search_path = public AS $$
DECLARE
    v_creative   ad_creatives%ROWTYPE;
    v_campaign   ad_campaigns%ROWTYPE;
    v_advertiser advertisers%ROWTYPE;
    v_user_email TEXT; v_user_role TEXT;
BEGIN
    SELECT * INTO v_creative FROM ad_creatives WHERE id = p_creative_id;
    IF NOT FOUND THEN RETURN jsonb_build_object('success',false,'error','Creative not found'); END IF;
    SELECT * INTO v_campaign   FROM ad_campaigns WHERE id = v_creative.campaign_id;
    SELECT * INTO v_advertiser FROM advertisers WHERE id = v_campaign.advertiser_id AND user_id = p_user_id;
    IF NOT FOUND THEN RETURN jsonb_build_object('success',false,'error','Not authorized'); END IF;
    IF v_creative.deleted_at IS NOT NULL THEN RETURN jsonb_build_object('success',false,'error','Creative is already deleted'); END IF;

    UPDATE ad_creatives SET status='archived', deleted_at=NOW(), deleted_by_user=TRUE,
        deletion_reason=p_reason, is_approved=FALSE, updated_at=NOW()
    WHERE id = p_creative_id;

    BEGIN
        SELECT email INTO v_user_email FROM auth.users WHERE id = p_user_id;
        SELECT COALESCE(role,'advertiser') INTO v_user_role FROM user_profiles WHERE id = p_user_id;
        INSERT INTO admin_activity_log (admin_id, admin_email, admin_role, action, target_type, target_id, description, metadata, created_at)
        VALUES (p_user_id, COALESCE(v_user_email,'unknown'), COALESCE(v_user_role,'advertiser'),
            'advertiser_delete_creative','ad_creative',p_creative_id,
            COALESCE(p_reason,'Creative deleted by advertiser'),
            jsonb_build_object('headline',v_creative.headline,'impressions',v_creative.impressions), NOW());
    EXCEPTION WHEN OTHERS THEN NULL;
    END;

    RETURN jsonb_build_object('success',true,'message','Ad creative archived. All impression and click records are preserved.');
EXCEPTION WHEN OTHERS THEN RETURN jsonb_build_object('success',false,'error',SQLERRM);
END;
$$;

