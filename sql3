-- Auto-start: when a creative is approved, set active + start campaign
CREATE OR REPLACE FUNCTION auto_start_campaign_on_approval()
RETURNS TRIGGER AS $$
BEGIN
    -- When is_approved becomes TRUE (from any previous value), activate creative + run campaign
    IF NEW.is_approved = TRUE AND (OLD.is_approved IS DISTINCT FROM TRUE) THEN
        -- Force creative to active so get_eligible_ads can pick it up
        NEW.status := 'active';
        -- Start the parent campaign regardless of its current status
        UPDATE ad_campaigns
        SET    status     = 'running',
               updated_at = NOW()
        WHERE  id         = NEW.campaign_id
          AND  deleted_at IS NULL;
    END IF;
    -- When is_approved becomes FALSE (rejection/removal), pause creative
    IF NEW.is_approved = FALSE AND OLD.is_approved = TRUE THEN
        NEW.status := 'paused';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

DROP TRIGGER IF EXISTS auto_start_on_creative_approval ON ad_creatives;
CREATE TRIGGER auto_start_on_creative_approval
    BEFORE UPDATE OF is_approved ON ad_creatives
    FOR EACH ROW EXECUTE FUNCTION auto_start_campaign_on_approval();


-- One-time fix: any creative already approved (is_approved=TRUE) must be active
-- This catches cases where admin approved but status never updated
UPDATE ad_creatives
SET    status     = 'active',
       updated_at = NOW()
WHERE  is_approved = TRUE
  AND  status     != 'active'
  AND  status     NOT IN ('rejected','archived')
  AND  deleted_at IS NULL;

-- One-time fix: any campaign that has at least one active approved creative → running
-- No date/status restriction so already-approved ads become visible immediately
UPDATE ad_campaigns
SET    status     = 'running',
       updated_at = NOW()
WHERE  deleted_at IS NULL
  AND  status    != 'cancelled'
  AND  EXISTS (
      SELECT 1 FROM ad_creatives cr
      WHERE  cr.campaign_id = ad_campaigns.id
        AND  cr.is_approved = TRUE
        AND  cr.status      = 'active'
        AND  cr.deleted_at  IS NULL
  );

-- One-time fix: delete impressions recorded today with wrong cost (full bidAmount
-- instead of bidAmount/1000). These inflated daily spend and triggered the daily
-- budget gate, causing 0 ads to be returned. Only deletes today's rows so
-- historical analytics are preserved.
DELETE FROM ad_impressions
WHERE cost > 1.00
  AND created_at >= CURRENT_DATE::TIMESTAMPTZ;

-- One-time fix: campaigns stored with wrong timezone (device local time saved as UTC).
-- Flutter was using DateTime.now().toIso8601String() which has no timezone suffix,
-- so Supabase stored Tanzania local time (UTC+3) as if it were UTC.
-- Result: a campaign created at 20:00 Tanzania time was stored as 20:00 UTC,
-- making start_date appear 3 hours in the future from the server's perspective.
-- This subtracts 3 hours from start/end dates to correct them.
-- Safe to run multiple times — only affects campaigns where start_date > NOW().
UPDATE ad_campaigns
SET
    start_date = start_date - INTERVAL '3 hours',
    end_date   = end_date   - INTERVAL '3 hours',
    updated_at = NOW()
WHERE
    start_date > NOW() - INTERVAL '1 day'
    AND deleted_at IS NULL;

-- ============================================================================
-- One-time fix: repair ad_creatives.landing_url rows broken by the Dart
-- string-interpolation bug in create_creative_screen._submit(). landing_url was
-- built with single-quoted Dart strings and ESCAPED dollar signs (\$), so the
-- LITERAL placeholder text was stored instead of the real value:
--     phone    -> https://call.nyumba.co.tz/$digitsOnly
--     whatsapp -> https://wa.me/$rawWa?text=$msg
--     property -> https://property.nyumba.co.tz/${_selectedProperty!.id}
--     profile  -> https://profile.nyumba.co.tz/$userId
-- The Dart fix ships in the app build; this repairs already-stored rows.
-- Idempotent: "landing_url LIKE '%$%'" only matches still-broken rows, so this
-- is safe to re-run. Run it against LIVE data (like the one-time fixes above) —
-- NOT as part of a clean re-run of this whole file, whose PART 1 drops the ad
-- tables. 'website' rows are intentionally left untouched (a pasted URL may
-- legitimately contain '$').
-- ============================================================================

-- property -> rebuild from the correctly-stored linked_property_id
UPDATE ad_creatives
SET    landing_url = 'https://property.nyumba.co.tz/' || linked_property_id::TEXT,
       updated_at  = NOW()
WHERE  destination_type   = 'property'
  AND  landing_url        LIKE '%$%'
  AND  linked_property_id IS NOT NULL;

-- profile -> rebuild from the campaign's advertiser user_id
UPDATE ad_creatives AS c
SET    landing_url = 'https://profile.nyumba.co.tz/' || a.user_id::TEXT,
       updated_at  = NOW()
FROM   ad_campaigns AS cam
JOIN   advertisers  AS a ON a.id = cam.advertiser_id
WHERE  c.campaign_id      = cam.id
  AND  c.destination_type = 'profile'
  AND  c.landing_url      LIKE '%$%';

-- phone + whatsapp -> the number/message were never persisted, so the URL
-- cannot be rebuilt. Pause these so dead links stop serving; the advertiser
-- re-opens the ad and re-enters the number (the fixed app then stores it right).
UPDATE ad_creatives
SET    status     = 'paused',
       updated_at = NOW()
WHERE  destination_type IN ('phone','whatsapp')
  AND  landing_url LIKE '%$%';

-- ============================================================================
-- SELCOM WEBHOOK PAYMENT VERIFICATION
-- Called server-side by a Supabase Edge Function when Selcom confirms payment.
-- This is independent of whether the mobile app is open — fixes the background
-- polling gap where users who backgrounded the app never got their funds credited.
-- ============================================================================
CREATE OR REPLACE FUNCTION verify_and_complete_payment(
    p_transaction_id   TEXT,
    p_provider_reference TEXT,
    p_amount           DECIMAL,
    p_advertiser_id    UUID
)
RETURNS JSONB AS $$
DECLARE
    v_payment_id  UUID;
    v_existing    TEXT;
BEGIN
    -- Idempotency: if payment already completed, return success without double-crediting
    SELECT status INTO v_existing
    FROM   advertiser_payments
    WHERE  transaction_id = p_transaction_id;

    IF v_existing = 'completed' THEN
        RETURN jsonb_build_object('success', true, 'message', 'Payment already recorded', 'duplicate', true);
    END IF;

    IF v_existing IS NULL THEN
        -- Payment record doesn't exist yet (webhook arrived before polling)
        INSERT INTO advertiser_payments (
            advertiser_id, amount, transaction_id, payment_method,
            provider_reference, status, completed_at
        )
        VALUES (
            p_advertiser_id, p_amount, p_transaction_id, 'mobile_money',
            p_provider_reference, 'completed', NOW()
        )
        RETURNING id INTO v_payment_id;
    ELSE
        -- Update existing pending payment to completed
        UPDATE advertiser_payments
        SET    status       = 'completed',
               completed_at = NOW(),
               provider_reference = COALESCE(provider_reference, p_provider_reference)
        WHERE  transaction_id = p_transaction_id
        RETURNING id INTO v_payment_id;
    END IF;

    -- Credit the advertiser's balance
    UPDATE advertisers
    SET    account_balance = account_balance + p_amount,
           updated_at      = NOW()
    WHERE  id = p_advertiser_id;

    -- Notify advertiser in-app
    INSERT INTO user_notifications (user_id, type, title, message, data, is_read, created_at)
    SELECT a.user_id,
           'payment_confirmed',
           '💰 Funds Added Successfully',
           'TZS ' || p_amount::BIGINT || ' has been added to your ad account.',
           jsonb_build_object('amount', p_amount, 'transaction_id', p_transaction_id, 'payment_id', v_payment_id),
           FALSE,
           NOW()
    FROM   advertisers a
    WHERE  a.id = p_advertiser_id
      AND  a.user_id IS NOT NULL;

    RETURN jsonb_build_object('success', true, 'payment_id', v_payment_id, 'duplicate', false);
EXCEPTION WHEN OTHERS THEN
    RETURN jsonb_build_object('success', false, 'error', SQLERRM);
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

GRANT EXECUTE ON FUNCTION verify_and_complete_payment(TEXT,TEXT,DECIMAL,UUID) TO authenticated, anon;

