-- ============================================================================
-- EXTENSION D: PROPERTY OWNERSHIP VERIFICATION SYSTEM
-- Two methods:
--   1. Near Owner  — GPS location (2 km tolerance) + live photo vs listing
--                    photos compared on-device with TFLite feature vectors.
--                    Threshold: total score ≥ 60 / 100 → Verified.
--   2. Far Owner   — ID card (NIDA / DL / Voter) + Hati (Title Deed).
--                    ML Kit OCR reads both; fuzzy token name match ≥ 70% → Verified.
-- Binary result only: 'verified' or 'rejected' — no manual review state.
-- All comparison done on-device. Only the final result is written here.
-- ============================================================================

-- ── Cleanup (idempotent re-runs) ──────────────────────────────────────────────
DO $$
BEGIN
    -- Only drop the trigger if the table actually exists (first-run safety).
    IF EXISTS (
        SELECT 1 FROM pg_tables
        WHERE  schemaname = 'public' AND tablename = 'property_verifications'
    ) THEN
        DROP TRIGGER IF EXISTS trg_fraud_on_rejected_verification ON property_verifications;
    END IF;

    DROP FUNCTION IF EXISTS flag_repeated_verification_failures()                                                                      CASCADE;
    DROP FUNCTION IF EXISTS log_ownership_verification(UUID,UUID,TEXT,TEXT,INT,INT,INT,NUMERIC,TEXT,TEXT,TEXT,NUMERIC,TEXT,TEXT,TEXT) CASCADE;
    -- Also drop any older overloads from previous deployments
    DROP FUNCTION IF EXISTS log_ownership_verification(UUID,UUID,TEXT,TEXT,INT,INT,INT,NUMERIC,TEXT,TEXT,NUMERIC,JSONB)               CASCADE;
    DROP TABLE    IF EXISTS verification_fraud_signals CASCADE;
    DROP TABLE    IF EXISTS property_verifications     CASCADE;
    RAISE NOTICE 'Verification cleanup complete';
END $$;

-- ── property_verifications ────────────────────────────────────────────────────
-- One row per verification attempt.  property_id is NULL while the user is
-- still building the listing form (verification runs before first save).
-- It is filled in by log_ownership_verification() once the property exists.
CREATE TABLE property_verifications (
    id                  UUID            PRIMARY KEY DEFAULT gen_random_uuid(),
    property_id         UUID            REFERENCES properties(id) ON DELETE SET NULL,
    user_id             UUID            NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,

    -- Which method did the owner choose?
    method              TEXT            NOT NULL
                        CHECK (method IN ('near_owner', 'far_owner')),

    -- Final binary result
    status              TEXT            NOT NULL
                        CHECK (status IN ('verified', 'rejected')),

    -- ── Near Owner fields ──────────────────────────────────────────────────
    -- GPS distance from phone to property at time of verification
    distance_meters     NUMERIC(10,2),
    -- Tiered GPS component (0–300m=40, 300m–1km=25, 1km–2km=10, >2km=0)
    gps_score           SMALLINT        CHECK (gps_score BETWEEN 0 AND 40),
    -- TFLite cosine-similarity between live photo and listing photos (0–60)
    photo_score         SMALLINT        CHECK (photo_score BETWEEN 0 AND 60),
    -- Combined score used for threshold decision (gps_score + photo_score, 0–100)
    total_score         SMALLINT        CHECK (total_score BETWEEN 0 AND 100),

    -- ── Far Owner fields ───────────────────────────────────────────────────
    -- Name tokens extracted from ID card by ML Kit OCR
    id_document_type    TEXT,           -- 'nida' | 'driving_license' | 'voter'
    id_name_extracted   TEXT,           -- raw name from ID OCR
    hati_name_extracted TEXT,           -- raw name from Hati OCR
    -- Token-intersection fuzzy match score (0.00–100.00)
    name_match_pct      NUMERIC(5,2)    CHECK (name_match_pct BETWEEN 0 AND 100),

    -- ── Diagnostics ────────────────────────────────────────────────────────
    rejection_reason    TEXT,           -- short human-readable reason if rejected
    device_locale       TEXT,           -- e.g. 'sw_TZ'
    app_version         TEXT,

    created_at          TIMESTAMPTZ     DEFAULT NOW()
);

CREATE INDEX idx_pv_user_id      ON property_verifications(user_id);
CREATE INDEX idx_pv_property_id  ON property_verifications(property_id) WHERE property_id IS NOT NULL;
CREATE INDEX idx_pv_status       ON property_verifications(status, created_at DESC);

-- ── verification_fraud_signals ────────────────────────────────────────────────
-- Written by the trigger below whenever a rejection occurs.
-- Also writable from app-side for client-detected anomalies.
CREATE TABLE verification_fraud_signals (
    id              UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id         UUID        NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
